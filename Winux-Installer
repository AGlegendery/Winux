select_desktop_environment() {
    echo
    echo -e "${C_MAGENTA}${C_BOLD}SELECT DESKTOP ENVIRONMENT${C_RESET}"
    echo
    echo -e "  ${C_GREEN}${C_BOLD}[1]${C_RESET} KDE Plasma     ${C_YELLOW}(default)${C_RESET}"
    echo -e "  ${C_GREEN}${C_BOLD}[2]${C_RESET} XFCE"
    echo -e "  ${C_GREEN}${C_BOLD}[3]${C_RESET} GNOME"
    echo -e "  ${C_GREEN}${C_BOLD}[4]${C_RESET} LXQt"
    echo -e "  ${C_GREEN}${C_BOLD}[5]${C_RESET} Minimal X11"
    echo

    local choice result
    read -r -p "$(echo -e "${C_BOLD}Your choice [1]: ${C_RESET}")" choice
    choice="${choice:-1}"

    case "$choice" in
        1) result="kde" ;;
        2) result="xfce" ;;
        3) result="gnome" ;;
        4) result="lxqt" ;;
        5) result="minimal" ;;
        *) result="kde" ;;
    esac

    SELECTED_DE="$result"
}

ask_hardware_options() {
    echo
    echo -e "${C_MAGENTA}${C_BOLD}GPU OPTION${C_RESET}"
    echo -e "  NVIDIA proprietary? ${C_GREEN}yes${C_RESET}/${C_RED}no${C_RESET}"
    echo

    local ans result
    read -r -p "$(echo -e "${C_BOLD}Install NVIDIA? [no]: ${C_RESET}")" ans
    ans="${ans:-no}"

    case "$ans" in
        y|Y|yes|YES) result="yes" ;;
        *) result="no" ;;
    esac

    INSTALL_NVIDIA="$result"
}

select_disk_interactive() {
    echo
    echo -e "${C_MAGENTA}${C_BOLD}SELECT TARGET DISK${C_RESET}"
    echo

    local -a disk_paths=() disk_info=()
    local line path type

    while IFS= read -r line; do
        path=$(echo "$line" | awk '{print $1}')
        type=$(echo "$line" | awk '{print $NF}')
        [[ "$type" == "disk" ]] || continue
        disk_paths+=("$path")
        disk_info+=("$line")
    done < <(lsblk -dno NAME,SIZE,MODEL,TYPE 2>/dev/null | grep -E '^\S+\s+\S+.*disk$')

    if (( ${#disk_paths[@]} == 0 )); then
        echo -e "${C_RED}[ERROR] No disks detected${C_RESET}"
        exit 1
    fi

    local i=1
    for info in "${disk_info[@]}"; do
        echo -e "  ${C_GREEN}${C_BOLD}[$i]${C_RESET} $info"
        ((i++))
    done

    echo
    read -r -p "$(echo -e "${C_BOLD}Your choice: ${C_RESET}")" choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#disk_paths[@]} )); then
        local selected_disk="${disk_paths[$((choice-1))]}"
        [[ "$selected_disk" =~ ^/dev/ ]] || selected_disk="/dev/$selected_disk"
        [[ -b "$selected_disk" ]] || { echo "Invalid device"; exit 1; }
        SELECTED_DISK="$selected_disk"
    else
        echo "Invalid choice"
        exit 1
    fi
}

is_pkg_available() {
    pacman -Si "$1" >/dev/null 2>&1
}

is_group_available() {
    pacman -Sg "$1" >/dev/null 2>&1
}

adaptive_install() {
    local label="$1"
    shift
    local logger="${1:-$INSTALL_LOGGER}"
    shift
    
    local -a items=("$@") pkgs=() groups=() missing=()

    Logger::info "$logger" "Resolving: $label"

    for item in "${items[@]}"; do
        [[ -z "$item" ]] && continue
        if is_pkg_available "$item"; then
            pkgs+=("$item")
        elif is_group_available "$item"; then
            groups+=("$item")
        else
            missing+=("$item")
        fi
    done

    if (( ${#missing[@]} > 0 )); then
        Logger::error "$logger" "Unavailable: ${missing[*]}"
        exit 1
    fi

    if (( ${#groups[@]} > 0 )); then
        retry_with_logging "$logger" "$PACMAN_RETRY_COUNT" "$PACMAN_RETRY_SLEEP" pacman -S --needed --noconfirm "${groups[@]}"
    fi

    if (( ${#pkgs[@]} > 0 )); then
        retry_with_logging "$logger" "$PACMAN_RETRY_COUNT" "$PACMAN_RETRY_SLEEP" pacman -S --needed --noconfirm "${pkgs[@]}"
    fi
}

adaptive_install_optional() {
    local label="$1"
    shift
    local logger="${1:-$INSTALL_LOGGER}"
    shift
    
    local -a items=("$@") available=()

    for item in "${items[@]}"; do
        [[ -z "$item" ]] && continue
        if is_pkg_available "$item" || is_group_available "$item"; then
            available+=("$item")
        fi
    done

    if (( ${#available[@]} > 0 )); then
        adaptive_install "$label" "$logger" "${available[@]}"
    fi
}

# ============================================================
# INSTALLER FUNCTIONS
# ============================================================

partition_disk() {
    local disk="$1"
    local logger="${2:-$INSTALL_LOGGER}"
    
    WINUX_PHASE="partitioning"
    
    confirm_danger "This will ERASE ALL DATA on: $disk"
    
    Logger::info "$logger" "Partitioning: $disk"
    state_set_metadata "selected_disk" "$disk"
    
    wipefs -af "$disk"
    sgdisk --zap-all "$disk"
    
    parted -s "$disk" mklabel gpt
    parted -s "$disk" mkpart ESP fat32 1MiB 1025MiB
    parted -s "$disk" set 1 esp on
    parted -s "$disk" mkpart ROOT ext4 1025MiB 100%
    
    partprobe "$disk"
    sleep 2
    
    local efi_part root_part
    
    if [[ "$disk" =~ nvme|mmcblk ]]; then
        efi_part="${disk}p1"
        root_part="${disk}p2"
    else
        efi_part="${disk}1"
        root_part="${disk}2"
    fi
    
    [[ -b "$efi_part" ]] || { Logger::fatal "$logger" "EFI not found: $efi_part"; exit 1; }
    [[ -b "$root_part" ]] || { Logger::fatal "$logger" "Root not found: $root_part"; exit 1; }
    
    mkfs.fat -F32 "$efi_part"
    mkfs.ext4 -F "$root_part"
    
    mkdir -p "$MNT"
    mount "$root_part" "$MNT"
    mkdir -p "$MNT/boot"
    mount "$efi_part" "$MNT/boot"
    
    state_set_metadata "efi_part" "$efi_part"
    state_set_metadata "root_part" "$root_part"
}

pacstrap_base() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    WINUX_PHASE="pacstrap"
    
    if ! check_connection_stability "$logger"; then
        Logger::fatal "$logger" "Unstable connection"
        exit 1
    fi
    
    pacstrap -K "$MNT" "${BASE_PACKAGES[@]}" | tee -a "$INSTALL_LOG"
    genfstab -U "$MNT" >> "$MNT/etc/fstab"
}

write_target_pacman_config() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    cp /etc/pacman.d/mirrorlist "$MNT/etc/pacman.d/mirrorlist"
    harden_pacman_conf "$logger" "$MNT"
    enable_multilib "$logger" "$MNT"
}

write_chroot_script() {
    local hostname="$1" username="$2" root_b64="$3" user_b64="$4"
    local selected_de="$5" install_nvidia="$6"
    local logger="${7:-$INSTALL_LOGGER}"
    
    cat > "$MNT/root/winux-chroot.sh" <<CHROOT_EOF
#!/usr/bin/env bash
set -Eeuo pipefail

HOSTNAME='$hostname'
USERNAME='$username'
ROOT_PASS_B64='$root_b64'
USER_PASS_B64='$user_b64'
TIMEZONE='$TIMEZONE_DEFAULT'
LOCALE='$LOCALE_DEFAULT'
KEYMAP='$KEYMAP_DEFAULT'
DE='$selected_de'
NVIDIA='$install_nvidia'

log() { echo "[Winux Chroot][\$(date '+%Y-%m-%d %H:%M:%S')] \$*"; }

decode_b64() { printf '%s' "\$1" | base64 -d; }

log "Setting timezone..."
ln -sf "/usr/share/zoneinfo/\$TIMEZONE" /etc/localtime
hwclock --systohc || true

log "Configuring locale..."
sed -i "s/^#\${LOCALE}/\${LOCALE}/" /etc/locale.gen
locale-gen
echo "LANG=\$LOCALE" > /etc/locale.conf
echo "KEYMAP=\$KEYMAP" > /etc/vconsole.conf

log "Setting hostname..."
echo "\$HOSTNAME" > /etc/hostname

cat > /etc/hosts <<'HOSTS'
127.0.0.1   localhost
::1         localhost
127.0.1.1   \$HOSTNAME.localdomain \$HOSTNAME
HOSTS

log "Setting root password..."
echo "root:\$(decode_b64 \$ROOT_PASS_B64)" | chpasswd

log "Creating user..."
if ! id "\$USERNAME" >/dev/null 2>&1; then
    useradd -m -G wheel,audio,video,input,storage,optical,lp,network,power -s /bin/bash "\$USERNAME"
fi
echo "\$USERNAME:\$(decode_b64 \$USER_PASS_B64)" | chpasswd

log "Enabling sudo..."
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

log "Enabling services..."
systemctl enable NetworkManager.service
systemctl enable sshd.service

log "Installing GRUB..."
grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=Winux --recheck
sed -i 's/^#GRUB_DISABLE_OS_PROBER=.*/GRUB_DISABLE_OS_PROBER=false/' /etc/default/grub || true
grub-mkconfig -o /boot/grub/grub.cfg

log "Writing config..."
cat > /etc/winux.conf <<'CONF'
WINUX_VERSION="$WINUX_VERSION"
WINUX_USERNAME="\$USERNAME"
WINUX_DE="\$DE"
WINUX_INSTALL_NVIDIA="\$NVIDIA"
CONF

log "Installing runtime service..."
cat > /etc/systemd/system/winux-runtime.service <<'SERVICE'
[Unit]
Description=Winux Runtime Installer
After=network-online.target
Wants=network-online.target
ConditionPathExists=/usr/local/bin/winux-installer.sh
ConditionPathExists=!/var/lib/winux-runtime.done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/winux-installer.sh --runtime
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
SERVICE

systemctl enable winux-runtime.service

log "Chroot completed."
CHROOT_EOF

    chmod +x "$MNT/root/winux-chroot.sh"
}

install_self_to_target() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    mkdir -p "$MNT/usr/local/bin"
    cp "$0" "$MNT$RUNTIME_SCRIPT"
    chmod +x "$MNT$RUNTIME_SCRIPT"
}

run_chroot_script() {
    local logger="${1:-$INSTALL_LOGGER}"
    arch-chroot "$MNT" /root/winux-chroot.sh | tee -a "$INSTALL_LOG"
}

finish_live_install() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    umount -R "$MNT" || true
    state_set "$STATE_COMPLETE" "$logger"
    
    echo
    echo -e "${C_GREEN}${C_BOLD}Base installation completed!${C_RESET}"
    echo -e "${C_CYAN}Reboot now. Runtime will run automatically.${C_RESET}"
    echo
}

run_live_install() {
    require_root
    init_install_logger
    setup_error_trap "$INSTALL_LOGGER"
    
    print_banner
    WINUX_PHASE="live-install-start"
    
    Logger::info "$INSTALL_LOGGER" "Starting Winux Installer v${WINUX_VERSION}"
    
    state_init "$INSTALL_LOGGER"
    state_validate "$INSTALL_LOGGER"
    
    if state_check_complete; then
        Logger::warn "$INSTALL_LOGGER" "Already completed. Use --reset."
        return 0
    fi
    
    state_resume_from "$INSTALL_LOGGER" >/dev/null
    
    check_boot_mode
    check_internet "$INSTALL_LOGGER"
    sync_time "$INSTALL_LOGGER"
    
    configure_reflector "$INSTALL_LOGGER"
    harden_pacman_conf "$INSTALL_LOGGER"
    pacman_refresh "$INSTALL_LOGGER"
    pacman_sanity_check "$INSTALL_LOGGER"
    
    local selected_de install_nvidia hostname username root_pass user_pass root_b64 user_b64 disk
    
    select_desktop_environment
    selected_de="$SELECTED_DE"
    
    ask_hardware_options
    install_nvidia="$INSTALL_NVIDIA"
    
    hostname="$(ask "Hostname" "$HOSTNAME_DEFAULT")"
    username="$(ask "Username" "$USERNAME_DEFAULT")"
    
    echo
    root_pass="$(ask_secret "Root password")"
    echo
    user_pass="$(ask_secret "Password for '$username'")"
    
    root_b64="$(printf '%s' "$root_pass" | base64 -w0)"
    user_b64="$(printf '%s' "$user_pass" | base64 -w0)"
    
    select_disk_interactive
    disk="$SELECTED_DISK"
    
    state_set "$STATE_PARTITION" "$INSTALL_LOGGER"
    partition_disk "$disk" "$INSTALL_LOGGER"
    
    state_set "$STATE_MOUNT" "$INSTALL_LOGGER"
    
    state_set "$STATE_BASE_INSTALL" "$INSTALL_LOGGER"
    pacstrap_base "$INSTALL_LOGGER"
    
    write_target_pacman_config "$INSTALL_LOGGER"
    install_self_to_target "$INSTALL_LOGGER"
    
    state_set "$STATE_CHROOT" "$INSTALL_LOGGER"
    write_chroot_script "$hostname" "$username" "$root_b64" "$user_b64" "$selected_de" "$install_nvidia" "$INSTALL_LOGGER"
    run_chroot_script "$INSTALL_LOGGER"
    
    finish_live_install "$INSTALL_LOGGER"
}

# ============================================================
# RUNTIME FUNCTIONS
# ============================================================

load_runtime_config() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
        Logger::info "$logger" "Config loaded from $CONFIG_FILE"
    fi
    
    WINUX_USERNAME="${WINUX_USERNAME:-$USERNAME_DEFAULT}"
    WINUX_DE="${WINUX_DE:-kde}"
    WINUX_INSTALL_NVIDIA="${WINUX_INSTALL_NVIDIA:-no}"
}

runtime_prepare() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-prepare"
    
    mkdir -p /var/log
    touch "$RUNTIME_LOG"
    
    Logger::info "$logger" "Starting Winux runtime v${WINUX_VERSION}"
    
    check_internet "$logger"
    sync_time "$logger"
    
    configure_reflector "$logger"
    harden_pacman_conf "$logger"
    enable_multilib "$logger"
    pacman_refresh "$logger"
    pacman_sanity_check "$logger"
    
    state_set "$STATE_RUNTIME_PREPARE" "$logger"
}

install_core_runtime() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-core"
    
    adaptive_install "core-runtime" "$logger" "${CORE_RUNTIME_PACKAGES[@]}"
    
    systemctl enable bluetooth.service || true
    systemctl enable cups.service || true
    systemctl enable avahi-daemon.service || true
    
    state_set "$STATE_RUNTIME_CORE" "$logger"
}

install_de_runtime() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-de"
    
    case "$WINUX_DE" in
        kde)
            adaptive_install "desktop-kde" "$logger" "${KDE_PACKAGES[@]}"
            systemctl enable sddm.service
            ;;
        xfce)
            adaptive_install "desktop-xfce" "$logger" "${XFCE_PACKAGES[@]}"
            systemctl enable lightdm.service
            ;;
        gnome)
            adaptive_install "desktop-gnome" "$logger" "${GNOME_PACKAGES[@]}"
            systemctl enable gdm.service
            ;;
        lxqt)
            adaptive_install "desktop-lxqt" "$logger" "${LXQT_PACKAGES[@]}"
            systemctl enable sddm.service
            ;;
        minimal)
            adaptive_install "desktop-minimal" "$logger" "${MINIMAL_PACKAGES[@]}"
            systemctl enable lightdm.service
            ;;
        *)
            WINUX_DE="kde"
            install_de_runtime
            ;;
    esac
    
    state_set "$STATE_RUNTIME_DE" "$logger"
}

install_nvidia_if_requested() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-nvidia"
    
    if [[ "$WINUX_INSTALL_NVIDIA" != "yes" ]]; then
        return 0
    fi
    
    adaptive_install_optional "nvidia" "$logger" "${NVIDIA_PACKAGES[@]}"
}

install_full_wine_stack() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-wine-full"
    
    adaptive_install "wine-core" "$logger" "${WINE_CORE_PACKAGES[@]}"
    adaptive_install_optional "wine-optional" "$logger" "${WINE_OPTIONAL_PACKAGES[@]}"
    
    state_set "$STATE_RUNTIME_WINE" "$logger"
}

install_proton() {
    local logger="${1:-$RUNTIME_LOGGER}"
    local user="$WINUX_USERNAME"
    
    WINUX_PHASE="runtime-proton"
    
    local home_dir
    home_dir="$(getent passwd "$user" | cut -d: -f6 || true)"
    
    if [[ -z "$home_dir" || ! -d "$home_dir" ]]; then
        Logger::warn "$logger" "User home not found"
        return 0
    fi
    
    local compat_dir="$home_dir/$STEAM_COMPAT_DIR"
    mkdir -p "$compat_dir"
    
    Logger::info "$logger" "Installing Proton..."
    cd "$compat_dir" || return 1
    
    local proton_url
    proton_url=$(curl -s "https://api.github.com/repos/ValveSoftware/Proton/releases/latest" | grep "browser_download_url" | grep "Proton" | head -n 1 | cut -d '"' -f 4)
    
    if [[ -n "$proton_url" ]]; then
        local proton_file
        proton_file=$(basename "$proton_url")
        
        if [[ ! -d "${proton_file%.tar.gz}" ]]; then
            Logger::info "$logger" "Downloading $proton_file..."
            curl -L "$proton_url" -o "$proton_file"
            tar -xzf "$proton_file"
            rm -f "$proton_file"
        fi
    fi
    
    local ge_url
    ge_url=$(curl -s "https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest" | grep "browser_download_url" | grep "tar.gz" | head -n 1 | cut -d '"' -f 4)
    
    if [[ -n "$ge_url" ]]; then
        local ge_file
        ge_file=$(basename "$ge_url")
        
        if [[ ! -d "${ge_file%.tar.gz}" ]]; then
            Logger::info "$logger" "Downloading $ge_file..."
            curl -L "$ge_url" -o "$ge_file"
            tar -xzf "$ge_file"
            rm -f "$ge_file"
        fi
    fi
    
    chown -R "$user:$user" "$compat_dir"
    
    state_set "$STATE_RUNTIME_PROTON" "$logger"
}

apply_system_tuning() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    WINUX_PHASE="runtime-tuning"
    
    cat > /etc/sysctl.d/99-winux-gaming.conf <<EOF
vm.max_map_count = $VM_MAX_MAP_COUNT
fs.file-max = $FS_FILE_MAX
net.core.rmem_max = $NET_CORE_RMEM_MAX
net.core.wmem_max = $NET_CORE_WMEM_MAX
net.ipv4.tcp_window_scaling = $NET_IPV4_TCP_WINDOW_SCALING
net.ipv4.tcp_sack = $NET_IPV4_TCP_SACK
net.ipv4.tcp_fack = $NET_IPV4_TCP_FACK
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_slow_start_after_idle = 0
net.ipv4.tcp_no_metrics_save = 1
EOF
    
    sysctl -p /etc/sysctl.d/99-winux-gaming.conf
    
    cat > /etc/security/limits.d/99-winux-gaming.conf <<EOF
* soft nofile 524288
* hard nofile 524288
* soft nproc 524288
* hard nproc 524288
EOF
    
    state_set "$STATE_RUNTIME_TUNING" "$logger"
}

create_winux_user_runtime() {
    local logger="${1:-$RUNTIME_LOGGER}"
    local user="$WINUX_USERNAME"
    
    WINUX_PHASE="runtime-user-prefix"
    
    local home_dir
    home_dir="$(getent passwd "$user" | cut -d: -f6 || true)"
    
    if [[ -z "$home_dir" || ! -d "$home_dir" ]]; then
        return 0
    fi
    
    install -d -m 755 "$home_dir/.winux"/{prefixes/{apps,games}} "$home_dir/.local/bin" "$home_dir/Desktop"
    
    cat > "$home_dir/.local/bin/winux-run-app" <<'EOF'
#!/usr/bin/env bash
export WINEPREFIX="$HOME/.winux/prefixes/apps"
export WINEARCH=win64
wine "$@"
EOF
    
    cat > "$home_dir/.local/bin/winux-run-game" <<'EOF'
#!/usr/bin/env bash
export WINEPREFIX="$HOME/.winux/prefixes/games"
export WINEARCH=win64
export DXVK_LOG_LEVEL=none
export WINEDEBUG=-all
if command -v gamemoderun >/dev/null 2>&1; then
    exec gamemoderun wine "$@"
else
    exec wine "$@"
fi
EOF
    
    chmod +x "$home_dir/.local/bin/winux-run-app" "$home_dir/.local/bin/winux-run-game"
    
    chown -R "$user:$user" "$home_dir/.winux" "$home_dir/.local" "$home_dir/Desktop"
    
    sudo -u "$user" env WINEPREFIX="$home_dir/.winux/prefixes/apps" WINEARCH=win64 wineboot -u || true
    sudo -u "$user" env WINEPREFIX="$home_dir/.winux/prefixes/games" WINEARCH=win64 wineboot -u || true
}

runtime_cleanup_and_mark_done() {
    local logger="${1:-$RUNTIME_LOGGER}"
    
    pacman -Sc --noconfirm || true
    
    mkdir -p /var/lib
    touch /var/lib/winux-runtime.done
    
    systemctl disable winux-runtime.service || true
    
    state_set "$STATE_COMPLETE" "$logger"
    
    echo
    echo -e "${C_GREEN}${C_BOLD}Runtime installation completed!${C_RESET}"
    echo -e "${C_CYAN}Desktop: $WINUX_DE | User: $WINUX_USERNAME${C_RESET}"
    echo
}

run_runtime() {
    require_root
    
    init_runtime_logger
    setup_error_trap "$RUNTIME_LOGGER"
    
    exec > >(tee -a "$RUNTIME_LOG") 2>&1
    
    print_banner
    
    load_runtime_config "$RUNTIME_LOGGER"
    
    state_init "$RUNTIME_LOGGER"
    state_validate "$RUNTIME_LOGGER"
    
    if state_check_complete; then
        Logger::warn "$RUNTIME_LOGGER" "Already completed"
        return 0
    fi
    
    state_resume_from "$RUNTIME_LOGGER" >/dev/null
    
    runtime_prepare "$RUNTIME_LOGGER"
    install_core_runtime "$RUNTIME_LOGGER"
    install_de_runtime "$RUNTIME_LOGGER"
    install_nvidia_if_requested "$RUNTIME_LOGGER"
    install_full_wine_stack "$RUNTIME_LOGGER"
    install_proton "$RUNTIME_LOGGER"
    apply_system_tuning "$RUNTIME_LOGGER"
    create_winux_user_runtime "$RUNTIME_LOGGER"
    runtime_cleanup_and_mark_done "$RUNTIME_LOGGER"
}

# ============================================================
# MAIN ENTRY POINT
# ============================================================

show_version() {
    echo "Winux Installer v${WINUX_VERSION} (${WINUX_RELEASE})"
}

show_usage() {
    echo "Usage: $0 [OPTION]"
    echo
    echo "Options:"
    echo "  (none)      Run live ISO installation"
    echo "  --runtime   Run runtime phase (after reboot)"
    echo "  --reset     Reset installation"
    echo "  --state     Show installation state"
    echo "  --version   Show version"
    echo "  --help      Show this help"
    echo
}

main() {
    case "${1:-}" in
        --runtime)
            run_runtime
            ;;
        --reset)
            require_root
            init_install_logger
            state_reset "$INSTALL_LOGGER" "false"
            ;;
        --state)
            state_show
            ;;
        --version)
            show_version
            ;;
        --help|-h)
            show_usage
            ;;
        *)
            run_live_install
            ;;
    esac
}

main "$@"
