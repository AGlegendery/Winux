#!/usr/bin/env bash
# ============================================================
# Winux Installer v0.5 Final Hardened
# Arch Linux + selectable DE + Full Wine Stack
# Author: Winux Project
# Mode:
#   Live ISO: run normally
#   Installed system runtime: --runtime
# ============================================================

set -Eeuo pipefail

VERSION="0.5-final"
HOSTNAME_DEFAULT="winux"
USERNAME_DEFAULT="winux"
TIMEZONE_DEFAULT="Asia/Tehran"
LOCALE_DEFAULT="en_US.UTF-8"
KEYMAP_DEFAULT="us"

INSTALL_LOG="/var/log/winux-installer.log"
RUNTIME_LOG="/var/log/winux-runtime.log"
CONFIG_FILE="/etc/winux.conf"

MNT="/mnt"
RUNTIME_SCRIPT="/usr/local/bin/winux-installer.sh"
RUNTIME_SERVICE="/etc/systemd/system/winux-runtime.service"

PACMAN_RETRY_COUNT=5
PACMAN_RETRY_SLEEP=6

SELECTED_DE="kde"
INSTALL_NVIDIA="no"

# -----------------------------
# Colors (cosmetic only)
# -----------------------------

if [[ -t 1 ]]; then
    C_RESET="\e[0m"
    C_BOLD="\e[1m"
    C_RED="\e[31m"
    C_GREEN="\e[32m"
    C_YELLOW="\e[33m"
    C_BLUE="\e[34m"
    C_MAGENTA="\e[35m"
    C_CYAN="\e[36m"
    C_WHITE="\e[97m"
else
    C_RESET=""; C_BOLD=""; C_RED=""; C_GREEN=""; C_YELLOW=""
    C_BLUE=""; C_MAGENTA=""; C_CYAN=""; C_WHITE=""
fi

print_banner() {
    echo -e "${C_CYAN}${C_BOLD}"
    cat <<'EOF'
 _       ___                     ____              __  _
| |     / (_)___  __  ___  __   / __ \__  ______  / /_(_)___ ___  ___
| | /| / / / __ \/ / / / |/_/  / /_/ / / / / __ \/ __/ / __ `__ \/ _ \
| |/ |/ / / / / / /_/ />  <   / _, _/ /_/ / / / / /_/ / / / / / /  __/
|__/|__/_/_/ /_/\__,_/_/|_|  /_/ |_|\__,_/_/ /_/\__/_/_/ /_/ /_/\___/

EOF
    echo -e "${C_RESET}${C_YELLOW}${C_BOLD}          Winux Installer v${VERSION}${C_RESET}"
    echo -e "${C_BLUE}     Arch Linux + Desktop Environment + Wine Runtime${C_RESET}"
    echo -e "${C_MAGENTA}------------------------------------------------------------${C_RESET}"
    echo
}

# -----------------------------
# Logging
# -----------------------------

mkdir -p /var/log

log() {
    local msg="$*"
    echo -e "[Winux][$(date '+%Y-%m-%d %H:%M:%S')] $msg" | tee -a "$INSTALL_LOG"
}

runtime_log() {
    local msg="$*"
    echo -e "[Winux Runtime][$(date '+%Y-%m-%d %H:%M:%S')] $msg" | tee -a "$RUNTIME_LOG"
}

die() {
    local msg="$*"
    echo
    echo "============================================================" | tee -a "$INSTALL_LOG"
    echo "[FATAL] $msg" | tee -a "$INSTALL_LOG"
    echo "============================================================" | tee -a "$INSTALL_LOG"
    exit 1
}

on_error() {
    local exit_code=$?
    local line_no=${1:-unknown}
    local cmd=${2:-unknown}
    echo
    echo "============================================================" | tee -a "$INSTALL_LOG"
    echo "[ERROR] Failure at line: $line_no" | tee -a "$INSTALL_LOG"
    echo "[ERROR] Exit code: $exit_code" | tee -a "$INSTALL_LOG"
    echo "[ERROR] Command: $cmd" | tee -a "$INSTALL_LOG"
    echo "[ERROR] Phase hint: ${WINUX_PHASE:-unknown}" | tee -a "$INSTALL_LOG"
    echo "============================================================" | tee -a "$INSTALL_LOG"
    exit "$exit_code"
}

trap 'on_error "$LINENO" "$BASH_COMMAND"' ERR

require_root() {
    if [[ "${EUID}" -ne 0 ]]; then
        die "This script must be run as root."
    fi
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# -----------------------------
# Basic helpers
# -----------------------------

ask() {
    local prompt="$1"
    local default="${2:-}"
    local answer

    if [[ -n "$default" ]]; then
        read -r -p "$(echo -e "${C_BOLD}${prompt}${C_RESET} [${C_YELLOW}${default}${C_RESET}]: ")" answer
        echo "${answer:-$default}"
    else
        read -r -p "$(echo -e "${C_BOLD}${prompt}${C_RESET}: ")" answer
        echo "$answer"
    fi
}

ask_secret() {
    local prompt="$1"
    local a b

    while true; do
        read -r -s -p "$(echo -e "${C_BOLD}${prompt}${C_RESET}: ")" a
        echo
        read -r -s -p "$(echo -e "${C_BOLD}Repeat ${prompt}${C_RESET}: ")" b
        echo

        if [[ -z "$a" ]]; then
            echo -e "${C_RED}Password cannot be empty.${C_RESET}"
            continue
        fi

        if [[ "$a" != "$b" ]]; then
            echo -e "${C_RED}Passwords do not match.${C_RESET}"
            continue
        fi

        printf '%s' "$a"
        return 0
    done
}

confirm_danger() {
    local prompt="$1"
    local answer
    echo
    echo -e "${C_RED}${C_BOLD}!!! DANGER !!!${C_RESET}"
    echo -e "${C_RED}${prompt}${C_RESET}"
    read -r -p "$(echo -e "${C_BOLD}Type EXACTLY 'YES' to continue: ${C_RESET}")" answer
    [[ "$answer" == "YES" ]] || die "User aborted."
}

# -----------------------------
# Mirror hardening
# -----------------------------

write_hardened_mirrorlist() {
    WINUX_PHASE="mirror-hardening"

    log "Writing hardened mirrorlist..."

    cat > /etc/pacman.d/mirrorlist <<'EOF'
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirror.leaseweb.net/archlinux/$repo/os/$arch
Server = https://ftp.halifax.rwth-aachen.de/archlinux/$repo/os/$arch
Server = https://mirror.sunred.org/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
EOF

    log "Mirrorlist updated."
}

harden_pacman_conf() {
    WINUX_PHASE="pacman-conf-hardening"

    log "Hardening pacman.conf..."

    if ! grep -q '^ParallelDownloads' /etc/pacman.conf; then
        sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf || true
    else
        sed -i 's/^ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf
    fi

    if grep -q '^#Color' /etc/pacman.conf; then
        sed -i 's/^#Color/Color/' /etc/pacman.conf
    fi

    if ! grep -q '^ILoveCandy' /etc/pacman.conf; then
        sed -i '/^Color/a ILoveCandy' /etc/pacman.conf || true
    fi
}

enable_multilib() {
    WINUX_PHASE="enable-multilib"

    log "Enabling multilib repository..."

    if grep -q '^\[multilib\]' /etc/pacman.conf; then
        log "multilib already enabled."
    else
        sed -i '/^\#\[multilib\]/,+1 s/^\#//' /etc/pacman.conf || true
    fi

    if ! grep -q '^\[multilib\]' /etc/pacman.conf; then
        cat >> /etc/pacman.conf <<'EOF'

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
    fi
}

pacman_refresh() {
    WINUX_PHASE="pacman-refresh"

    log "Refreshing pacman database..."
    rm -f /var/lib/pacman/db.lck || true
    rm -f /var/cache/pacman/pkg/*.part || true

    pacman -Syy --noconfirm | tee -a "$INSTALL_LOG"
}

pacman_sanity_check() {
    WINUX_PHASE="pacman-sanity-check"

    log "Running pacman mirror sanity check..."

    local test_pkgs=(
        "filesystem"
        "bash"
        "pacman"
    )

    for pkg in "${test_pkgs[@]}"; do
        log "Checking repository visibility for: $pkg"
        pacman -Si "$pkg" >/dev/null 2>&1 || die "Repository sanity check failed. Cannot see package: $pkg"
    done

    log "Pacman sanity check passed."
}

retry_cmd() {
    local n=1
    local max="$PACMAN_RETRY_COUNT"
    local delay="$PACMAN_RETRY_SLEEP"

    until "$@"; do
        local exit_code=$?

        if (( n >= max )); then
            log "Command failed after $n attempts: $*"
            return "$exit_code"
        fi

        log "Command failed attempt $n/$max: $*"
        log "Cleaning partial downloads and refreshing database before retry..."
        rm -f /var/cache/pacman/pkg/*.part || true
        rm -f /var/lib/pacman/db.lck || true
        sleep "$delay"

        pacman -Syy --noconfirm || true

        ((n++))
    done
}

retry_pacman_install() {
    WINUX_PHASE="pacman-install"
    retry_cmd pacman -S --needed --noconfirm "$@"
}

# -----------------------------
# Package / group resolver
# -----------------------------

is_pkg_available() {
    local item="$1"
    pacman -Si "$item" >/dev/null 2>&1
}

is_group_available() {
    local item="$1"
    pacman -Sg "$item" >/dev/null 2>&1
}

print_unavailable_report() {
    local -a missing=("$@")

    echo
    echo -e "${C_RED}${C_BOLD}================ PACKAGE RESOLUTION FAILED ================${C_RESET}" | tee -a "$INSTALL_LOG"
    echo "Unavailable items:" | tee -a "$INSTALL_LOG"

    for item in "${missing[@]}"; do
        echo "  - $item" | tee -a "$INSTALL_LOG"
    done

    echo -e "${C_RED}${C_BOLD}===========================================================${C_RESET}" | tee -a "$INSTALL_LOG"
    echo
}

adaptive_install() {
    WINUX_PHASE="adaptive-install"

    local label="$1"
    shift

    local -a items=("$@")
    local -a pkgs=()
    local -a groups=()
    local -a missing=()

    log "Resolving install batch: $label"

    for item in "${items[@]}"; do
        [[ -z "$item" ]] && continue

        if is_pkg_available "$item"; then
            log "Package OK: $item"
            pkgs+=("$item")
        elif is_group_available "$item"; then
            log "Group OK: $item"
            groups+=("$item")
        else
            log "Unavailable: $item"
            missing+=("$item")
        fi
    done

    if (( ${#missing[@]} > 0 )); then
        print_unavailable_report "${missing[@]}"
        die "Some packages/groups are unavailable. See report above."
    fi

    if (( ${#groups[@]} > 0 )); then
        log "Installing groups for batch: $label"
        retry_pacman_install "${groups[@]}"
    fi

    if (( ${#pkgs[@]} > 0 )); then
        log "Installing packages for batch: $label"
        retry_pacman_install "${pkgs[@]}"
    fi

    log "Batch installed successfully: $label"
}

adaptive_install_optional() {
    WINUX_PHASE="adaptive-install-optional"

    local label="$1"
    shift

    local -a items=("$@")
    local -a available=()
    local -a skipped=()

    log "Resolving optional batch: $label"

    for item in "${items[@]}"; do
        [[ -z "$item" ]] && continue

        if is_pkg_available "$item" || is_group_available "$item"; then
            available+=("$item")
            log "Optional available: $item"
        else
            skipped+=("$item")
            log "Optional skipped, unavailable: $item"
        fi
    done

    if (( ${#available[@]} > 0 )); then
        adaptive_install "$label" "${available[@]}"
    fi

    if (( ${#skipped[@]} > 0 )); then
        log "Optional unavailable items in $label:"
        for item in "${skipped[@]}"; do
            log "  - $item"
        done
    fi
}

# -----------------------------
# Live ISO install phase
# -----------------------------

check_boot_mode() {
    WINUX_PHASE="boot-mode-check"

    if [[ ! -d /sys/firmware/efi/efivars ]]; then
        die "This installer currently expects UEFI boot. Boot the Arch ISO in UEFI mode."
    fi

    log "UEFI mode detected."
}

check_internet() {
    WINUX_PHASE="network-check"

    log "Checking internet connectivity..."

    if ping -c 2 archlinux.org >/dev/null 2>&1; then
        log "Internet OK."
    elif ping -c 2 1.1.1.1 >/dev/null 2>&1; then
        log "Internet OK via IP, DNS may be weak but continuing."
    else
        die "No internet connectivity."
    fi
}

sync_time() {
    WINUX_PHASE="time-sync"

    log "Enabling NTP..."
    timedatectl set-ntp true || true
    sleep 2
    timedatectl status | tee -a "$INSTALL_LOG" || true
}

select_desktop_environment() {
    echo
    echo -e "${C_MAGENTA}${C_BOLD}============================================================${C_RESET}"
    echo -e "${C_MAGENTA}${C_BOLD}                 SELECT DESKTOP ENVIRONMENT                 ${C_RESET}"
    echo -e "${C_MAGENTA}${C_BOLD}============================================================${C_RESET}"
    echo
    echo -e "  ${C_GREEN}${C_BOLD}[1]${C_RESET} KDE Plasma     ${C_YELLOW}(recommended / default)${C_RESET}"
    echo -e "  ${C_GREEN}${C_BOLD}[2]${C_RESET} XFCE"
    echo -e "  ${C_GREEN}${C_BOLD}[3]${C_RESET} GNOME"
    echo -e "  ${C_GREEN}${C_BOLD}[4]${C_RESET} LXQt"
    echo -e "  ${C_GREEN}${C_BOLD}[5]${C_RESET} Minimal X11"
    echo
    echo -e "${C_CYAN}Enter the number of your choice.${C_RESET}"
    echo -e "${C_CYAN}Example: to pick option 1 (KDE Plasma), type ${C_BOLD}1${C_RESET}${C_CYAN} and press Enter.${C_RESET}"
    echo

    local choice
    read -r -p "$(echo -e "${C_BOLD}Your choice [1]: ${C_RESET}")" choice
    choice="${choice:-1}"

    case "$choice" in
        1) SELECTED_DE="kde" ;;
        2) SELECTED_DE="xfce" ;;
        3) SELECTED_DE="gnome" ;;
        4) SELECTED_DE="lxqt" ;;
        5) SELECTED_DE="minimal" ;;
        *)
            echo -e "${C_RED}Invalid choice. Using KDE.${C_RESET}"
            SELECTED_DE="kde"
            ;;
    esac

    log "Selected DE: $SELECTED_DE"
}

ask_hardware_options() {
    echo
    echo -e "${C_MAGENTA}${C_BOLD}------------------------------------------------------------${C_RESET}"
    echo -e "${C_MAGENTA}${C_BOLD} GPU OPTION${C_RESET}"
    echo -e "${C_MAGENTA}${C_BOLD}------------------------------------------------------------${C_RESET}"
    echo -e "  If you are on ${C_YELLOW}NVIDIA${C_RESET} proprietary driver target, answer ${C_GREEN}yes${C_RESET}."
    echo -e "  Otherwise ${C_GREEN}no${C_RESET} is safer for Intel/AMD/VM."
    echo

    local ans
    read -r -p "$(echo -e "${C_BOLD}Install NVIDIA proprietary packages? [no]: ${C_RESET}")" ans
    ans="${ans:-no}"

    case "$ans" in
        y|Y|yes|YES) INSTALL_NVIDIA="yes" ;;
        *) INSTALL_NVIDIA="no" ;;
    esac

    log "Install NVIDIA: $INSTALL_NVIDIA"
}

select_disk() {
    WINUX_PHASE="disk-selection"

    echo
    echo -e "${C_MAGENTA}${C_BOLD}Available disks:${C_RESET}"
    lsblk -dpno NAME,SIZE,MODEL,TYPE | awk '$4=="disk"{print}'
    echo

    local disk
    disk="$(ask "Target disk, example /dev/sda or /dev/nvme0n1")"

    [[ -b "$disk" ]] || die "Invalid block device: $disk"

    echo "$disk"
}

partition_disk() {
    WINUX_PHASE="partitioning"

    local disk="$1"

    confirm_danger "This will ERASE ALL DATA on: $disk"

    log "Partitioning disk: $disk"

    wipefs -af "$disk"
    sgdisk --zap-all "$disk"

    parted -s "$disk" mklabel gpt
    parted -s "$disk" mkpart ESP fat32 1MiB 1025MiB
    parted -s "$disk" set 1 esp on
    parted -s "$disk" mkpart ROOT ext4 1025MiB 100%

    partprobe "$disk"
    sleep 2

    local efi_part root_part

    if [[ "$disk" =~ nvme|mmcblk ]]; then
        efi_part="${disk}p1"
        root_part="${disk}p2"
    else
        efi_part="${disk}1"
        root_part="${disk}2"
    fi

    [[ -b "$efi_part" ]] || die "EFI partition not found: $efi_part"
    [[ -b "$root_part" ]] || die "Root partition not found: $root_part"

    log "Formatting EFI: $efi_part"
    mkfs.fat -F32 "$efi_part"

    log "Formatting root: $root_part"
    mkfs.ext4 -F "$root_part"

    mkdir -p "$MNT"

    log "Mounting root: $root_part"
    mount "$root_part" "$MNT"

    mkdir -p "$MNT/boot"
    log "Mounting EFI: $efi_part -> $MNT/boot"
    mount "$efi_part" "$MNT/boot"

    echo "$root_part"
}

