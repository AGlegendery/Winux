write_target_pacman_config() {
    WINUX_PHASE="target-pacman-config"

    log "Copying hardened pacman configuration to target..."
    cp /etc/pacman.d/mirrorlist "$MNT/etc/pacman.d/mirrorlist"

    if grep -q '^#Color' "$MNT/etc/pacman.conf"; then
        sed -i 's/^#Color/Color/' "$MNT/etc/pacman.conf"
    fi

    if grep -q '^#ParallelDownloads' "$MNT/etc/pacman.conf"; then
        sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' "$MNT/etc/pacman.conf"
    elif ! grep -q '^ParallelDownloads' "$MNT/etc/pacman.conf"; then
        sed -i '/^\[options\]/a ParallelDownloads = 5' "$MNT/etc/pacman.conf"
    fi

    if ! grep -q '^ILoveCandy' "$MNT/etc/pacman.conf"; then
        sed -i '/^Color/a ILoveCandy' "$MNT/etc/pacman.conf" || true
    fi

    if ! grep -q '^\[multilib\]' "$MNT/etc/pacman.conf"; then
        cat >> "$MNT/etc/pacman.conf" <<'EOF'

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
    fi
}

write_chroot_script() {
    WINUX_PHASE="write-chroot-script"

    local hostname="$1"
    local username="$2"
    local root_b64="$3"
    local user_b64="$4"
    local selected_de="$5"
    local install_nvidia="$6"

    log "Writing chroot configuration script..."

    cat > "$MNT/root/winux-chroot.sh" <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail

HOSTNAME_VALUE='$hostname'
USERNAME_VALUE='$username'
ROOT_PASS_B64='$root_b64'
USER_PASS_B64='$user_b64'
TIMEZONE_VALUE='$TIMEZONE_DEFAULT'
LOCALE_VALUE='$LOCALE_DEFAULT'
KEYMAP_VALUE='$KEYMAP_DEFAULT'
SELECTED_DE='$selected_de'
INSTALL_NVIDIA='$install_nvidia'

log() {
    echo "[Winux Chroot][\$(date '+%Y-%m-%d %H:%M:%S')] \$*"
}

decode_b64() {
    printf '%s' "\$1" | base64 -d
}

log "Setting timezone..."
ln -sf "/usr/share/zoneinfo/\$TIMEZONE_VALUE" /etc/localtime
hwclock --systohc || true

log "Configuring locale..."
sed -i "s/^#\${LOCALE_VALUE}/\${LOCALE_VALUE}/" /etc/locale.gen
locale-gen
echo "LANG=\$LOCALE_VALUE" > /etc/locale.conf
echo "KEYMAP=\$KEYMAP_VALUE" > /etc/vconsole.conf

log "Setting hostname..."
echo "\$HOSTNAME_VALUE" > /etc/hostname

cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   \$HOSTNAME_VALUE.localdomain \$HOSTNAME_VALUE
HOSTS

log "Setting root password..."
echo "root:\$(decode_b64 "\$ROOT_PASS_B64")" | chpasswd

log "Creating user..."
if ! id "\$USERNAME_VALUE" >/dev/null 2>&1; then
    useradd -m -G wheel,audio,video,input,storage,optical,lp,network,power -s /bin/bash "\$USERNAME_VALUE"
fi

echo "\$USERNAME_VALUE:\$(decode_b64 "\$USER_PASS_B64")" | chpasswd

log "Enabling sudo for wheel..."
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

log "Enabling core services..."
systemctl enable NetworkManager.service
systemctl enable sshd.service

log "Installing GRUB for UEFI..."
grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=Winux --recheck

log "Generating GRUB config..."
sed -i 's/^#GRUB_DISABLE_OS_PROBER=.*/GRUB_DISABLE_OS_PROBER=false/' /etc/default/grub || true
grub-mkconfig -o /boot/grub/grub.cfg

log "Writing Winux config..."
cat > /etc/winux.conf <<CONF
WINUX_VERSION="$VERSION"
WINUX_USERNAME="\$USERNAME_VALUE"
WINUX_DE="\$SELECTED_DE"
WINUX_INSTALL_NVIDIA="\$INSTALL_NVIDIA"
CONF

log "Installing runtime service..."
cat > /etc/systemd/system/winux-runtime.service <<SERVICE
[Unit]
Description=Winux Runtime Installer
After=network-online.target
Wants=network-online.target
ConditionPathExists=/usr/local/bin/winux-installer.sh
ConditionPathExists=!/var/lib/winux-runtime.done

[Service]
Type=oneshot
ExecStart=/usr/local/bin/winux-installer.sh --runtime
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
SERVICE

systemctl enable winux-runtime.service

log "Chroot phase completed."
EOF

    chmod +x "$MNT/root/winux-chroot.sh"
}

install_self_to_target() {
    WINUX_PHASE="install-self"

    log "Installing this script into target system..."

    mkdir -p "$MNT/usr/local/bin"
    cp "$0" "$MNT$RUNTIME_SCRIPT"
    chmod +x "$MNT$RUNTIME_SCRIPT"
}

run_chroot_script() {
    WINUX_PHASE="run-chroot"

    log "Running chroot script..."
    arch-chroot "$MNT" /root/winux-chroot.sh | tee -a "$INSTALL_LOG"
}

finish_live_install() {
    WINUX_PHASE="finish-live-install"

    log "Base installation completed."
    log "Unmounting target..."
    umount -R "$MNT" || true

    echo
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
    echo -e "${C_GREEN}${C_BOLD}          Winux base installation completed!               ${C_RESET}"
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
    echo -e "${C_CYAN}Now reboot. Runtime phase will continue automatically.${C_RESET}"
    echo
    echo -e "${C_YELLOW}After reboot, if runtime fails or you need resume:${C_RESET}"
    echo -e "  ${C_BOLD}sudo /usr/local/bin/winux-installer.sh --runtime${C_RESET}"
    echo
    echo -e "${C_BLUE}Logs:${C_RESET}"
    echo "  /var/log/winux-installer.log"
    echo "  /var/log/winux-runtime.log"
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
}

run_live_install() {
    require_root

    print_banner

    WINUX_PHASE="live-install-start"

    log "Starting Winux Installer v$VERSION"

    check_boot_mode
    check_internet
    sync_time

    write_hardened_mirrorlist
    harden_pacman_conf
    pacman_refresh
    pacman_sanity_check

    select_desktop_environment
    ask_hardware_options

    local hostname username root_pass user_pass root_b64 user_b64 disk

    hostname="$(ask "Hostname" "$HOSTNAME_DEFAULT")"
    username="$(ask "Username" "$USERNAME_DEFAULT")"

    echo
    root_pass="$(ask_secret "Root password")"
    echo
    user_pass="$(ask_secret "Password for user '$username'")"

    root_b64="$(printf '%s' "$root_pass" | base64 -w0)"
    user_b64="$(printf '%s' "$user_pass" | base64 -w0)"

    disk="$(select_disk)"

    partition_disk "$disk"
    pacstrap_base
    write_target_pacman_config
    install_self_to_target
    write_chroot_script "$hostname" "$username" "$root_b64" "$user_b64" "$SELECTED_DE" "$INSTALL_NVIDIA"
    run_chroot_script
    finish_live_install
}

# -----------------------------
# Runtime phase
# -----------------------------

load_runtime_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    fi

    WINUX_USERNAME="${WINUX_USERNAME:-$USERNAME_DEFAULT}"
    WINUX_DE="${WINUX_DE:-kde}"
    WINUX_INSTALL_NVIDIA="${WINUX_INSTALL_NVIDIA:-no}"
}

runtime_prepare() {
    WINUX_PHASE="runtime-prepare"

    mkdir -p /var/log
    touch "$RUNTIME_LOG"

    runtime_log "Starting Winux runtime v$VERSION"

    check_internet
    sync_time

    write_hardened_mirrorlist
    harden_pacman_conf
    enable_multilib
    pacman_refresh
    pacman_sanity_check
}

