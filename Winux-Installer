# ============================================================
# LOGGER CLASS
# ============================================================

Logger::new() {
    local this="$1"
    local log_file="${2:-$INSTALL_LOG}"
    local component_name="${3:-Winux}"
    
    mkdir -p "$(dirname "$log_file")" 2>/dev/null || true
    touch "$log_file" 2>/dev/null || true
    
    eval "${this}_log_file='$log_file'"
    eval "${this}_component='$component_name'"
    eval "${this}_log_level='INFO'"
}

Logger::_log() {
    local this="$1"
    local level="$2"
    local color="$3"
    local message="$4"
    
    local component log_file timestamp
    component="$(eval "echo \${${this}_component}")"
    log_file="$(eval "echo \${${this}_log_file}")"
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    
    local log_msg="[${component}][${timestamp}][${level}] ${message}"
    
    if [[ -t 1 ]]; then
        echo -e "${color}${log_msg}${C_RESET}"
    else
        echo "$log_msg"
    fi
    
    echo "$log_msg" >> "$log_file" 2>/dev/null || true
}

Logger::debug() { Logger::_log "$1" "DEBUG" "$C_CYAN" "$2"; }
Logger::info() { Logger::_log "$1" "INFO" "$C_GREEN" "$2"; }
Logger::warn() { Logger::_log "$1" "WARN" "$C_YELLOW" "$2"; }
Logger::error() { Logger::_log "$1" "ERROR" "$C_RED" "$2"; }
Logger::fatal() { Logger::_log "$1" "FATAL" "${C_BOLD}${C_RED}" "$2"; }

Logger::error_handler() {
    local this="$1"
    local exit_code="$2"
    local line_no="$3"
    local command="$4"
    
    Logger::error "$this" "============================================================"
    Logger::error "$this" "Failure at line: $line_no"
    Logger::error "$this" "Exit code: $exit_code"
    Logger::error "$this" "Command: $command"
    Logger::error "$this" "Phase hint: ${WINUX_PHASE:-unknown}"
    Logger::error "$this" "============================================================"
}

init_install_logger() {
    INSTALL_LOGGER="install_logger"
    Logger::new "$INSTALL_LOGGER" "$INSTALL_LOG" "Winux-Installer"
}

init_runtime_logger() {
    RUNTIME_LOGGER="runtime_logger"
    Logger::new "$RUNTIME_LOGGER" "$RUNTIME_LOG" "Winux-Runtime"
}

setup_error_trap() {
    local logger="${1:-$INSTALL_LOGGER}"
    trap 'Logger::error_handler "'"$logger"'" $? "$LINENO" "$BASH_COMMAND"' ERR
}

retry_with_logging() {
    local logger="$1"
    local max_attempts="$2"
    local delay="$3"
    shift 3
    local command=("$@")
    
    local attempt=1
    while (( attempt <= max_attempts )); do
        if "${command[@]}"; then
            return 0
        fi
        
        if (( attempt < max_attempts )); then
            Logger::warn "$logger" "Retry attempt $attempt/$max_attempts for: ${command[*]}"
            sleep "$delay"
            ((attempt++))
        else
            Logger::error "$logger" "Command failed after $max_attempts attempts: ${command[*]}"
            return 1
        fi
    done
}

# ============================================================
# STATE MANAGEMENT
# ============================================================

state_init() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    mkdir -p "$STATE_DIR"
    touch "$STATE_FILE"
    
    if [[ ! -s "$STATE_FILE" ]]; then
        echo "current_state=$STATE_INIT" > "$STATE_FILE"
        echo "start_time=$(date '+%s')" >> "$STATE_FILE"
        echo "version=$WINUX_VERSION" >> "$STATE_FILE"
    fi
    
    Logger::info "$logger" "State initialized: $STATE_FILE"
}

state_get_current() {
    if [[ -f "$STATE_FILE" ]]; then
        grep '^current_state=' "$STATE_FILE" | cut -d'=' -f2
    else
        echo "$STATE_INIT"
    fi
}

state_set() {
    local new_state="$1"
    local logger="${2:-$INSTALL_LOGGER}"
    
    sed -i "s/^current_state=.*/current_state=$new_state/" "$STATE_FILE"
    echo "${new_state}_time=$(date '+%s')" >> "$STATE_FILE"
    
    Logger::info "$logger" "State updated: $new_state"
}

state_get() {
    local key="$1"
    if [[ -f "$STATE_FILE" ]]; then
        grep "^${key}=" "$STATE_FILE" | cut -d'=' -f2
    fi
}

state_set_metadata() {
    local key="$1"
    local value="$2"
    sed -i "/^${key}=/d" "$STATE_FILE"
    echo "${key}=${value}" >> "$STATE_FILE"
}

state_check_complete() {
    [[ "$(state_get_current)" == "$STATE_COMPLETE" ]]
}

state_is_initialized() {
    [[ -f "$STATE_FILE" && -s "$STATE_FILE" ]]
}

state_resume_from() {
    local current_state
    local logger="${1:-$INSTALL_LOGGER}"
    
    current_state="$(state_get_current)"
    Logger::info "$logger" "Resuming from state: $current_state"
    
    case "$current_state" in
        "$STATE_INIT") return 0 ;;
        "$STATE_PARTITION") return 1 ;;
        "$STATE_MOUNT") return 2 ;;
        "$STATE_BASE_INSTALL") return 3 ;;
        "$STATE_CHROOT") return 4 ;;
        "$STATE_RUNTIME_PREPARE") return 5 ;;
        "$STATE_RUNTIME_CORE") return 6 ;;
        "$STATE_RUNTIME_DE") return 7 ;;
        "$STATE_RUNTIME_WINE") return 8 ;;
        "$STATE_RUNTIME_PROTON") return 9 ;;
        "$STATE_RUNTIME_TUNING") return 10 ;;
        "$STATE_COMPLETE")
            Logger::warn "$logger" "Installation already completed"
            return 11
            ;;
        *)
            Logger::warn "$logger" "Unknown state: $current_state, starting fresh"
            state_set "$STATE_INIT" "$logger"
            return 0
            ;;
    esac
}

state_reset() {
    local logger="${1:-$INSTALL_LOGGER}"
    local force="${2:-false}"
    
    Logger::warn "$logger" "RESETTING WINUX INSTALLATION"
    
    if [[ "$force" != "true" ]]; then
        echo
        echo -e "${C_RED}${C_BOLD}!!! DANGER !!!${C_RESET}"
        echo -e "${C_RED}This will REVERT ALL CHANGES made by Winux installer${C_RESET}"
        echo
        read -r -p "$(echo -e "${C_BOLD}Type EXACTLY 'YES' to continue: ${C_RESET}")" answer
        [[ "$answer" == "YES" ]] || { Logger::error "$logger" "Reset aborted"; return 1; }
    fi
    
    local selected_disk
    selected_disk="$(state_get "selected_disk")"
    
    umount -R "$MNT" 2>/dev/null || true
    systemctl disable winux-runtime.service 2>/dev/null || true
    systemctl stop winux-runtime.service 2>/dev/null || true
    
    rm -f "$STATE_FILE"
    rm -f /var/lib/winux-runtime.done 2>/dev/null || true
    rm -f "$RUNTIME_SERVICE"
    rm -f "$RUNTIME_SCRIPT"
    rm -f "$CONFIG_FILE"
    rm -f "$INSTALL_LOG"
    rm -f "$RUNTIME_LOG"
    
    if [[ -n "$selected_disk" && -b "$selected_disk" ]]; then
        wipefs -af "$selected_disk" 2>/dev/null || true
        sgdisk --zap-all "$selected_disk" 2>/dev/null || true
    fi
    
    rm -rf "$STATE_DIR"
    Logger::info "$logger" "Reset completed"
    return 0
}

state_validate() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    if ! state_is_initialized; then
        state_init "$logger"
        return 1
    fi
    
    local version
    version="$(state_get "version")"
    
    if [[ "$version" != "$WINUX_VERSION" ]]; then
        Logger::warn "$logger" "Version mismatch: state=$version, current=$WINUX_VERSION"
    fi
    
    return 0
}

state_show() {
    if ! state_is_initialized; then
        echo "State file not found"
        return 1
    fi
    
    echo "============================================================"
    echo "Winux Installation State"
    echo "============================================================"
    cat "$STATE_FILE"
    echo "============================================================"
}

# ============================================================
# NETWORK FUNCTIONS
# ============================================================

check_connection_stability() {
    local logger="${1:-$INSTALL_LOGGER}"
    local max_attempts="${CONNECTION_RETRY_COUNT}"
    local base_delay="${CONNECTION_RETRY_DELAY}"
    local threshold="${CONNECTION_STABILITY_THRESHOLD}"
    local timeout="${CONNECTION_STABILITY_TIMEOUT}"
    
    Logger::info "$logger" "Checking connection stability..."
    
    local attempt=1 stable_count=0 delay="$base_delay"
    
    while (( attempt <= max_attempts )); do
        if ping -c 1 -W "$timeout" "$CONNECTION_TEST_HOST" >/dev/null 2>&1; then
            ((stable_count++))
            if (( stable_count >= threshold )); then
                Logger::info "$logger" "Connection stable after $attempt attempts"
                return 0
            fi
        elif ping -c 1 -W "$timeout" "$CONNECTION_TEST_IP" >/dev/null 2>&1; then
            ((stable_count++))
            if (( stable_count >= threshold )); then
                Logger::info "$logger" "Connection stable via IP after $attempt attempts"
                return 0
            fi
        else
            stable_count=0
        fi
        
        if (( attempt < max_attempts )); then
            Logger::warn "$logger" "Connection unstable, waiting ${delay}s..."
            sleep "$delay"
            delay=$((delay * 2))
            ((attempt++))
        else
            Logger::error "$logger" "Connection failed stability check"
            return 1
        fi
    done
}

check_internet() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    Logger::info "$logger" "Checking internet connectivity..."
    
    if ping -c 2 "$CONNECTION_TEST_HOST" >/dev/null 2>&1; then
        Logger::info "$logger" "Internet OK"
        return 0
    elif ping -c 2 "$CONNECTION_TEST_IP" >/dev/null 2>&1; then
        Logger::info "$logger" "Internet OK via IP"
        return 0
    else
        Logger::error "$logger" "No internet connectivity"
        return 1
    fi
}

configure_reflector() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    Logger::info "$logger" "Configuring reflector..."
    
    if ! command -v reflector >/dev/null 2>&1; then
        pacman -S --needed --noconfirm reflector || return 1
    fi
    
    if ! check_connection_stability "$logger"; then
        write_fallback_mirrorlist "$logger"
        return 1
    fi
    
    if reflector \
        --country "$REFLECTOR_COUNTRIES" \
        --protocol "$REFLECTOR_PROTOCOL" \
        --sort "$REFLECTOR_SORT" \
        --score "$REFLECTOR_SCORE" \
        --latest "$REFLECTOR_LATEST" \
        --save /etc/pacman.d/mirrorlist; then
        Logger::info "$logger" "Reflector completed"
        return 0
    else
        write_fallback_mirrorlist "$logger"
        return 1
    fi
}

write_fallback_mirrorlist() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    Logger::warn "$logger" "Writing fallback mirrorlist..."
    
    cat > /etc/pacman.d/mirrorlist <<'EOF'
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirror.leaseweb.net/archlinux/$repo/os/$arch
Server = https://ftp.halifax.rwth-aachen.de/archlinux/$repo/os/$arch
Server = https://mirror.sunred.org/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
EOF
}

harden_pacman_conf() {
    local logger="${1:-$INSTALL_LOGGER}"
    local target="${2:-}"
    
    local conf_file="/etc/pacman.conf"
    [[ -n "$target" ]] && conf_file="${target}/etc/pacman.conf"
    
    if grep -q '^#ParallelDownloads' "$conf_file"; then
        sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' "$conf_file"
    elif ! grep -q '^ParallelDownloads' "$conf_file"; then
        sed -i '/^\[options\]/a ParallelDownloads = 5' "$conf_file"
    else
        sed -i 's/^ParallelDownloads.*/ParallelDownloads = 5/' "$conf_file"
    fi
    
    if grep -q '^#Color' "$conf_file"; then
        sed -i 's/^#Color/Color/' "$conf_file"
    fi
    
    if ! grep -q '^ILoveCandy' "$conf_file"; then
        sed -i '/^Color/a ILoveCandy' "$conf_file" || true
    fi
}

enable_multilib() {
    local logger="${1:-$INSTALL_LOGGER}"
    local target="${2:-}"
    
    local conf_file="/etc/pacman.conf"
    [[ -n "$target" ]] && conf_file="${target}/etc/pacman.conf"
    
    if grep -q '^\[multilib\]' "$conf_file"; then
        return 0
    fi
    
    if sed -i '/^\#\[multilib\]/,+1 s/^\#//' "$conf_file" 2>/dev/null; then
        Logger::info "$logger" "Multilib enabled"
    else
        cat >> "$conf_file" <<'EOF'

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
    fi
}

pacman_refresh() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    Logger::info "$logger" "Refreshing pacman database..."
    
    rm -f /var/lib/pacman/db.lck 2>/dev/null || true
    rm -f /var/cache/pacman/pkg/*.part 2>/dev/null || true
    
    if ! check_connection_stability "$logger"; then
        return 1
    fi
    
    retry_with_logging "$logger" "$PACMAN_RETRY_COUNT" "$PACMAN_RETRY_SLEEP" pacman -Syy --noconfirm
}

pacman_sanity_check() {
    local logger="${1:-$INSTALL_LOGGER}"
    
    Logger::info "$logger" "Running pacman sanity check..."
    
    for pkg in filesystem bash pacman; do
        pacman -Si "$pkg" >/dev/null 2>&1 || { Logger::error "$logger" "Cannot see package: $pkg"; return 1; }
    done
    
    Logger::info "$logger" "Pacman sanity check passed"
}

