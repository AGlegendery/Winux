#!/usr/bin/env bash
#
# Winux v0.2 Unified Installer (Run inside Arch Live ISO)
# Developer: Arash Ghasem
#
# این اسکریپت دو فاز دارد:
#   فاز 1 (Base)   : نصب پایه آرچ روی دیسک، پارتیشن، GRUB، کاربر.
#   فاز 2 (Runtime): نصب KDE، Wine، رانتایم‌ها، اکشن‌های فایل‌منیجر.
# فاز ۲ به‌صورت خودکار در اولین بوت توسط سرویس سیستمی اجرا می‌شود.
#
# === ERROR HANDLING ===
set -Eeuo pipefail
trap 'winux_err_handler $LINENO' ERR

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

winux_err_handler() {
    local line="$1"
    echo -e "${RED}[ERROR] Failure at line ${line} of phase: ${WINUX_PHASE:-unknown}.${NC}" >&2
    echo -e "${RED}Review the log above. Aborting.${NC}" >&2
    exit 1
}

log()  { echo -e "${GREEN}[$(date +%H:%M:%S)]${NC} $*"; }
info() { echo -e "${BLUE}[$(date +%H:%M:%S)]${NC} $*"; }
warn() { echo -e "${YELLOW}[$(date +%H:%M:%S)] WARNING:${NC} $*"; }

confirm() {
    # $1=prompt, $2=default (y/n)
    local prompt="$1" default="${2:-y}" reply
    if [[ "$default" =~ ^[Yy] ]]; then
        read -r -p "$prompt [Y/n] " reply
        reply="${reply:-y}"
    else
        read -r -p "$prompt [y/N] " reply
        reply="${reply:-n}"
    fi
    [[ "$reply" =~ ^[Yy]$ ]]
}

ask_value() {
    # $1=label, $2=default
    local label="$1" default="$2" value
    read -r -p "$label [default: $default]: " value
    echo "${value:-$default}"
}

ask_secret() {
    # $1=label, $2=default
    local label="$1" default="$2" value
    read -r -s -p "$label [default: hidden, press Enter to use]: " value
    echo
    echo "${value:-$default}"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || { echo -e "${RED}Missing required command: $1${NC}" >&2; exit 1; }
}

# ─────────────────────────────────────────────────────────────
#  مرحله صفر: تشخیص محیط و فاز
# ─────────────────────────────────────────────────────────────
detect_phase() {
    if [[ -f /etc/winux.conf && -x /usr/bin/pacman && ! -f /.dockerenv ]]; then
        # روی سیستم نصب‌شده (نه Live ISO) → فاز Runtime
        if grep -q 'root=x:0:0' /etc/passwd 2>/dev/null && [[ "$(id -u)" -eq 0 ]]; then
            WINUX_PHASE="runtime"
        else
            WINUX_PHASE="runtime-user"
        fi
    else
        WINUX_PHASE="base"
    fi
}

# ─────────────────────────────────────────────────────────────
#  مرحله ۱: سؤالات کاربر (فاز Base)
# ─────────────────────────────────────────────────────────────
collect_user_input() {
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║   Winux Installer — Configuration (defaults available)   ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════╝${NC}"

    info "Target disk selection."
    echo "Detected block devices:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL 2>/dev/null | sed 's/^/    /'
    echo

    local default_disk="/dev/sda"
    # اگر nvme وجود داشت، پیش‌فرض معقول‌تر باشد
    if ls /dev/nvme*n1 >/dev/null 2>&1; then default_disk="/dev/nvme0n1"; fi
    DISK="$(ask_value "Disk target (e.g. /dev/sda, /dev/nvme0n1)" "$default_disk")"

    if [[ ! -b "$DISK" ]]; then
        echo -e "${RED}Disk $DISK not found or not a block device. Aborting.${NC}" >&2
        exit 1
    fi

    HOSTNAME="$(ask_value "Hostname" "winux-pc")"
    USERNAME="$(ask_value "Username" "arash")"
    PASSWORD="$(ask_secret "Password" "123")"

    echo
    info "Timezone & Locale."
    TIMEZONE="$(ask_value "Timezone (Region/City)" "Asia/Tehran")"
    LOCALE="$(ask_value "Locale" "en_US.UTF-8")"

    echo
    info "Network configuration."
    echo "  1) Recommended  — full /etc/hosts with localdomain mapping (default)"
    echo "  2) Minimal      — localhost only"
    local net_choice
    read -r -p "Select network mode [1/2, default 1]: " net_choice
    net_choice="${net_choice:-1}"
    case "$net_choice" in
        2) NETWORK_MODE="minimal" ;;
        *) NETWORK_MODE="recommended" ;;
    esac

    echo
    echo -e "${YELLOW}═══════════════════ SUMMARY ═══════════════════${NC}"
    echo "  Disk     : $DISK"
    echo "  Hostname : $HOSTNAME"
    echo "  User     : $USERNAME"
    echo "  Password : ***(hidden)"
    echo "  Timezone : $TIMEZONE"
    echo "  Locale   : $LOCALE"
    echo "  Network  : $NETWORK_MODE"
    echo -e "${YELLOW}═════════════════════════════════════════════${NC}"
    echo
    echo -e "${RED}WARNING: All data on $DISK will be destroyed!${NC}"
    if ! confirm "Proceed with installation?" "n"; then
        echo "Aborted by user."
        exit 0
    fi
}

# ─────────────────────────────────────────────────────────────
#  پیش‌نیازها (فاز Base)
# ─────────────────────────────────────────────────────────────
preflight_checks() {
    log "Running preflight checks..."
    local cmds=(sgdisk mkfs.vfat mkfs.ext4 pacstrap arch-chroot genfstab)
    for c in "${cmds[@]}"; do require_cmd "$c"; done

    # UEFI check
    if [[ ! -d /sys/firmware/efi/efivars ]]; then
        echo -e "${RED}System is NOT booted in UEFI mode. This script requires UEFI.${NC}" >&2
        exit 1
    fi

    # Internet check
    info "Checking internet connectivity..."
    if ! ping -c1 -W3 archlinux.org >/dev/null 2>&1; then
        echo -e "${RED}No internet. Connect and retry.${NC}" >&2
        exit 1
    fi
    log "Internet OK."
}

# ─────────────────────────────────────────────────────────────
#  فاز ۱: نصب پایه
# ─────────────────────────────────────────────────────────────
phase_base() {
    WINUX_PHASE="base"
    echo -e "${BLUE}=== Starting Winux-v0.2 Arch Base Installation ===${NC}"

    collect_user_input
    preflight_checks

    # نگاشت پارتیشن‌ها (NVMe/loop نیاز به p دارند)
    PART_EFI="${DISK}1"
    PART_ROOT="${DISK}2"
    if [[ "$DISK" =~ nvme || "$DISK" =~ loop || "$DISK" =~ mmcblk ]]; then
        PART_EFI="${DISK}p1"
        PART_ROOT="${DISK}p2"
    fi

    # ۱. پارتیشن‌بندی
    log "Partitioning $DISK (UEFI/GPT)..."
    sgdisk --zap-all "$DISK"
    sgdisk --new=1:0:+512M --typecode=1:ef00 --change-name=1:EFI "$DISK"
    sgdisk --new=2:0:0 --typecode=2:8300 --change-name=2:ROOT "$DISK"
    partprobe "$DISK" 2>/dev/null || true
    sleep 1

    # ۲. فرمت
    log "Formatting partitions..."
    mkfs.vfat -F32 "$PART_EFI"
    mkfs.ext4 -F "$PART_ROOT"

    # ۳. Mount
    log "Mounting partitions..."
    mount "$PART_ROOT" /mnt
    mkdir -p /mnt/boot/efi
    mount "$PART_EFI" /mnt/boot/efi

    # ۴. pacstrap با retry
    log "Installing base system (pacstrap)..."
    local try
    for try in 1 2 3; do
        if pacstrap -K /mnt base base-devel linux linux-firmware nano networkmanager sudo; then
            break
        fi
        warn "pacstrap attempt $try failed, retrying in 5s..."
        sleep 5
        [[ "$try" -eq 3 ]] && { echo -e "${RED}pacstrap failed after 3 attempts.${NC}" >&2; exit 1; }
    done

    # ۵. fstab
    log "Generating fstab..."
    genfstab -U /mnt >> /mnt/etc/fstab

    # ۶. ذخیره پیکربندی برای استفاده در فاز‌های بعدی
    mkdir -p /mnt/etc
    cat > /mnt/etc/winux.conf <<CONF
# Winux installation configuration
WINUX_VERSION="0.2"
WINUX_DISK="$DISK"
WINUX_HOSTNAME="$HOSTNAME"
WINUX_USERNAME="$USERNAME"
WINUX_TIMEZONE="$TIMEZONE"
WINUX_LOCALE="$LOCALE"
WINUX_NETWORK_MODE="$NETWORK_MODE"
CONF

    # ۷. کپی اسکریپت فعلی به سیستم نصب‌شده برای فاز Runtime
    cp -- "$0" /mnt/usr/local/bin/winux-installer.sh
    chmod +x /mnt/usr/local/bin/winux-installer.sh

    # ۸. کانفیگ داخل chroot
    log "Configuring system inside chroot..."
    local net_hosts_block
    if [[ "$NETWORK_MODE" == "recommended" ]]; then
        net_hosts_block="127.0.0.1   localhost
::1         localhost
127.0.0.1   ${HOSTNAME}.localdomain ${HOSTNAME}"
    else
        net_hosts_block="127.0.0.1   localhost
::1         localhost"
    fi

    cat <<CHROOT_EOF | arch-chroot /mnt
set -e

# Timezone
ln -sf /usr/share/zoneinfo/${TIMEZONE} /etc/localtime
hwclock --systohc

# Locale
echo "${LOCALE} UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=${LOCALE}" > /etc/locale.conf

# Hostname
echo "${HOSTNAME}" > /etc/hostname
cat <<NET > /etc/hosts
${net_hosts_block}
NET

# User + sudo
useradd -m -G wheel -s /bin/bash ${USERNAME}
echo "${USERNAME}:${PASSWORD}" | chpasswd
echo "root:${PASSWORD}" | chpasswd
echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers.d/10-wheel
chmod 440 /etc/sudoers.d/10-wheel

# Bootloader
pacman -S --noconfirm grub efibootmgr
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Winux-GRUB
sed -i 's/GRUB_TIMEOUT=5/GRUB_TIMEOUT=0/' /etc/default/grub
sed -i 's/GRUB_TIMEOUT_STYLE=menu/GRUB_TIMEOUT_STYLE=hidden/' /etc/default/grub
grub-mkconfig -o /boot/grub/grub.cfg
CHROOT_EOF

    # ۹. ساخت سرویس اولین بوت برای اجرای فاز Runtime
    log "Creating first-boot service for runtime phase..."
    local SVC_DIR="/mnt/etc/systemd/system"
    cat > "$SVC_DIR/winux-runtime.service" <<SVC
[Unit]
Description=Winux Runtime Installer (Phase 2)
After=network-online.target sddm.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/winux-installer.sh --runtime
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1
RemainAfterExit=no
# خود-غیرفعال‌سازی بعد از اجرای موفق
ExecStartPost=/bin/sh -c 'systemctl disable winux-runtime.service'

[Install]
WantedBy=multi-user.target
SVC

    # فعال‌سازی سرویس
    arch-chroot /mnt systemctl enable winux-runtime.service 2>/dev/null || \
        ln -sf /etc/systemd/system/winux-runtime.service /mnt/etc/systemd/system/multi-user.target.wants/winux-runtime.service

    echo
    log "=== Base Installation Completed! ==="
    info "Unmount and reboot:"
    echo "    umount -R /mnt && reboot"
    echo
    info "Runtime phase will run automatically on first boot."
}

# ─────────────────────────────────────────────────────────────
#  درایور گرافیک: تشخیص خودکار GPU
# ─────────────────────────────────────────────────────────────
install_gpu_drivers() {
    local gpu=""
    if lspci -nn 2>/dev/null | grep -iE 'vga|3d|display' | grep -qi 'nvidia'; then
        gpu="nvidia"
    elif lspci -nn 2>/dev/null | grep -iE 'vga|3d|display' | grep -qi 'amd'; then
        gpu="amd"
    elif lspci -nn 2>/dev/null | grep -iE 'vga|3d|display' | grep -qi 'intel'; then
        gpu="intel"
    fi

    case "$gpu" in
        nvidia)
            info "NVIDIA GPU detected. Installing proprietary drivers..."
            pacman -S --needed --noconfirm \
                nvidia nvidia-utils lib32-nvidia-utils \
                nvidia-settings nvidia-dkms || {
                warn "NVIDIA driver install failed; continuing with fallback."; }
            # اطمینان از بارگذاری ماژول‌ها
            mkinitcpio -P 2>/dev/null || true
            ;;
        amd)
            info "AMD GPU detected. Installing Mesa + Vulkan RADV..."
            pacman -S --needed --noconfirm \
                mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon \
                libva-mesa-driver mesa-vdpau lib32-mesa-vdpau \
                amdvlk lib32-amdvlk || {
                warn "AMD driver install failed; continuing with fallback."; }
            ;;
        intel)
            info "Intel GPU detected. Installing Mesa + Vulkan ANV..."
            pacman -S --needed --noconfirm \
                mesa lib32-mesa vulkan-intel lib32-vulkan-intel \
                intel-media-driver libva-intel-driver || {
                warn "Intel driver install failed; continuing with fallback."; }
            ;;
        *)
            warn "No known GPU detected. Installing generic Mesa + Vulkan loaders..."
            pacman -S --needed --noconfirm mesa lib32-mesa vulkan-icd-loader lib32-vulkan-icd-loader || true
            ;;
    esac
}

# ─────────────────────────────────────────────────────────────
#  Steam + Proton (اختیاری)
# ─────────────────────────────────────────────────────────────
install_steam_proton() {
    if ! confirm "Install Steam (for native Proton gaming)?" "n"; then
        info "Skipping Steam/Proton."
        return 0
    fi

    info "Installing Steam + dependencies..."
    pacman -S --needed --noconfirm steam steam-native-runtime || {
        warn "Steam install failed; skipping."; return 0; }

    # نصب GE Proton (نسخه سفارشی Proton برای سازگاری بیشتر با بازی‌ها)
    if confirm "Install Proton-GE (custom Proton for better game compat)?" "y"; then
        local user_home ge_dir ge_ver ge_url
        user_home="$(getent passwd "$WINUX_USERNAME" | cut -d: -f6)"
        ge_dir="$user_home/.steam/root/compatibilitytools.d"
        sudo -u "$WINUX_USERNAME" -H mkdir -p "$ge_dir"

        # آخرین نسخه GE-Proton از GitHub
        ge_ver="$(curl -fsSL https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases/latest 2>/dev/null \
            | grep -oP '"tag_name":\s*"\K[^"]+' | head -n1)"

        if [[ -n "$ge_ver" ]]; then
            ge_url="https://github.com/GloriousEggroll/proton-ge-custom/releases/download/${ge_ver}/${ge_ver}.tar.gz"
            info "Downloading Proton-GE ${ge_ver}..."
            local tmp_tar="/tmp/${ge_ver}.tar.gz"
            if curl -fL -o "$tmp_tar" "$ge_url"; then
                sudo -u "$WINUX_USERNAME" -H tar -xzf "$tmp_tar" -C "$ge_dir"
                rm -f "$tmp_tar"
                log "Proton-GE ${ge_ver} installed to ${ge_dir}"
            else
                warn "Failed to download Proton-GE. Steam will use default Proton."
            fi
        else
            warn "Could not determine latest Proton-GE version. Skipping."
        fi
    fi
}

# ─────────────────────────────────────────────────────────────
#  فاز ۲: Runtime (داخل سیستم نصب‌شده، به‌عنوان root)
# ─────────────────────────────────────────────────────────────
phase_runtime_root() {
    WINUX_PHASE="runtime"
    # بارگذاری کانفیگ
    # shellcheck disable=SC1091
    source /etc/winux.conf 2>/dev/null || {
        echo -e "${RED}/etc/winux.conf missing. Cannot determine username.${NC}" >&2; exit 1; }

    echo -e "${BLUE}=== Starting Winux-v0.2 Runtime Installation (Phase 2) ===${NC}"

    # ۱. Multilib
    echo -e "${GREEN}[1/5] Enabling multilib repository...${NC}"
    if ! grep -q "^\[multilib\]" /etc/pacman.conf; then
        tee -a /etc/pacman.conf <<EOF

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
        echo -e "${GREEN}-> Multilib enabled.${NC}"
    else
        echo -e "${BLUE}-> Multilib already enabled.${NC}"
    fi

    # به‌روزرسانی
    echo -e "${GREEN}Syncing package databases...${NC}"
    local try
    for try in 1 2 3; do
        pacman -Syy && break
        warn "pacman -Syy attempt $try failed, retrying..."
        sleep 5
        [[ "$try" -eq 3 ]] && { echo -e "${RED}pacman sync failed.${NC}" >&2; exit 1; }
    done

    # ۲. KDE Plasma + ابزارها (PCManFM-Qt به‌عنوان فایل‌منیجر، نه Dolphin)
    echo -e "${GREEN}[2/7] Installing KDE Plasma, PCManFM-Qt, Audio/Video stack, Fonts...${NC}"
    pacman -S --needed --noconfirm \
        xorg xorg-server xorg-xinit \
        plasma-desktop sddm konsole \
        pcmanfm-qt lxqt-qtplugin lxqt-policykit \
        gvfs gvfs-mtp gvfs-smb gvfs-afc gvfs-gphoto2 \
        xarchiver firefox networkmanager git wget curl \
        pipewire pipewire-pulse pipewire-alsa pipewire-jack wireplumber \
        mesa lib32-mesa mesa-demos \
        vulkan-mesa-layers lib32-vulkan-mesa-layers \
        gamemode lib32-gamemode \
        noto-fonts noto-fonts-emoji ttf-dejavu gnu-free-fonts ttf-liberation \
        fontconfig freetype2 \
        ffmpeg gst-plugins-good gst-plugins-bad gst-plugins-ugly gst-libav \
        spectacle kde-gtk-config packagekit-qt6 || {
        echo -e "${RED}KDE/Desktop install failed.${NC}" >&2; exit 1; }

    systemctl enable sddm.service
    systemctl enable NetworkManager.service
    # صوت مدرن (Pipewire)
    systemctl --global enable pipewire.service pipewire-pulse.service 2>/dev/null || true

    # ۳. درایور گرافیک (تشخیص خودکار GPU برای بهترین کارایی)
    echo -e "${GREEN}[3/7] Detecting GPU and installing Vulkan/Mesa drivers...${NC}"
    install_gpu_drivers

    # ۴. Wine + تمام وابستگی‌های سیستمی (مجموعه کامل برای رفع missing libraries)
    echo -e "${GREEN}[4/7] Installing Wine, Winetricks, and complete 32/64-bit libraries...${NC}"
    pacman -S --needed --noconfirm \
        wine wine-mono wine-gecko winetricks \
        giflib lib32-giflib \
        libpng lib32-libpng \
        libxml2 lib32-libxml2 \
        libxslt lib32-libxslt \
        gnutls lib32-gnutls \
        mpg123 lib32-mpg123 \
        openal lib32-openal \
        v4l-utils lib32-v4l-utils \
        libpulse lib32-libpulse \
        libgpg-error lib32-libgpg-error \
        alsa-plugins lib32-alsa-plugins \
        alsa-lib lib32-alsa-lib \
        libjpeg-turbo lib32-jpeg-turbo \
        sqlite lib32-sqlite \
        libxcomposite lib32-libxcomposite \
        libxinerama lib32-libxinerama \
        libxcursor lib32-libxcursor \
        libxrandr lib32-libxrandr \
        libxi lib32-libxi \
        libxxf86vm lib32-libxxf86vm \
        libxrender lib32-libxrender \
        libcups lib32-libcups \
        libldap lib32-libldap \
        ocl-icd lib32-ocl-icd \
        libvkd3d lib32-libvkd3d \
        vkd3d \
        gsm lib32-gsm \
        sane sane-airscan \
        samba \
        ncurses lib32-ncurses \
        fontconfig lib32-fontconfig \
        vulkan-icd-loader lib32-vulkan-icd-loader || {
        echo -e "${RED}Wine install failed.${NC}" >&2; exit 1; }

    # ۵. Steam + Proton (اختیاری - برای بهترین تجربه گیمینگ)
    echo -e "${GREEN}[5/7] Steam + Proton setup (optional)...${NC}"
    install_steam_proton

    # ۶. اجرای بخش کاربر به‌عنوان کاربر ساخته‌شده
    echo -e "${GREEN}[6/7] Configuring Winux Runtimes for user: ${WINUX_USERNAME}...${NC}"
    local user_home
    user_home="$(getent passwd "$WINUX_USERNAME" | cut -d: -f6)"

    # اسکریپت کاربری موقت
    cat > /tmp/winux-user-setup.sh <<'USEREOF'
#!/usr/bin/env bash
set -e

mkdir -p "$HOME/.winux/prefixes/apps"
mkdir -p "$HOME/.winux/prefixes/games"
mkdir -p "$HOME/.local/bin"
mkdir -p "$HOME/.local/share/file-manager/actions"

# App runner
cat << 'APPEOF' > "$HOME/.local/bin/winux-run-app"
#!/usr/bin/env bash
export WINEPREFIX="$HOME/.winux/prefixes/apps"
export WINEARCH=win64
export WINEDEBUG=-all
if [ -z "$1" ]; then
    winecfg
else
    wine "$@"
fi
APPEOF

# Game runner
cat << 'GAMEEOF' > "$HOME/.local/bin/winux-run-game"
#!/usr/bin/env bash
export WINEPREFIX="$HOME/.winux/prefixes/games"
export WINEARCH=win64
export DXVK_HUD=fps
export WINEDEBUG=-all
if [ -z "$1" ]; then
    winecfg
else
    wine "$@"
fi
GAMEEOF

chmod +x "$HOME/.local/bin/winux-run-app" "$HOME/.local/bin/winux-run-game"

# Desktop actions
cat << APPEOF > "$HOME/.local/share/file-manager/actions/winux-app.desktop"
[Desktop Entry]
Type=Action
Name=Run with Winux Runtime
Icon=wine
Profiles=run_with_winux_app

[X-Action-Profile run_with_winux_app]
MimeTypes=application/x-msdownload;application/x-dosexec;
Exec=$HOME/.local/bin/winux-run-app %f
APPEOF

cat << GAMEEOF > "$HOME/.local/share/file-manager/actions/winux-game.desktop"
[Desktop Entry]
Type=Action
Name=Run with Winux Game Runtime
Icon=steam
Profiles=run_with_winux_game

[X-Action-Profile run_with_winux_game]
MimeTypes=application/x-msdownload;application/x-dosexec;
Exec=$HOME/.local/bin/winux-run-game %f
GAMEEOF

echo "User runtime configured."
USEREOF

    install -m755 -o "$WINUX_USERNAME" -g "$WINUX_USERNAME" /tmp/winux-user-setup.sh "$user_home/.winux-user-setup.sh"
    rm -f /tmp/winux-user-setup.sh

    # اجرا به‌عنوان کاربر
    if ! sudo -u "$WINUX_USERNAME" -H bash "$user_home/.winux-user-setup.sh"; then
        echo -e "${RED}User runtime setup failed.${NC}" >&2; exit 1;
    fi
    rm -f "$user_home/.winux-user-setup.sh"

    # ۷. پایان
    echo -e "${GREEN}[7/7] Runtime installation complete.${NC}"

    # غیرفعال‌سازی سرویس (مجدد، برای اطمینان)
    systemctl disable winux-runtime.service 2>/dev/null || true

    echo
    echo -e "${GREEN}=== Winux v0.2 fully installed! Please reboot. ===${NC}"
}

# ─────────────────────────────────────────────────────────────
#  فاز ۲ کاربر: اگر اسکریپت توسط کاربر اجرا شد (manual)
# ─────────────────────────────────────────────────────────────
phase_runtime_user() {
    WINUX_PHASE="runtime-user"
    echo -e "${BLUE}=== Winux Runtime (user-run mode) ===${NC}"
    echo -e "${YELLOW}This needs root for pacman. Re-run with: sudo $0 --runtime${NC}"
    exit 1
}

# ─────────────────────────────────────────────────────────────
#  Main
# ─────────────────────────────────────────────────────────────
main() {
    # آرگومان صریح
    case "${1:-}" in
        --runtime)
            if [[ "$(id -u)" -eq 0 ]]; then
                phase_runtime_root
            else
                phase_runtime_user
            fi
            exit 0
            ;;
        --base)
            phase_base
            exit 0
            ;;
        --help|-h)
            echo "Usage: $0 [--base|--runtime|--help]"
            echo "  (no arg) : auto-detect phase"
            exit 0
            ;;
    esac

    # تشخیص خودکار
    detect_phase
    case "$WINUX_PHASE" in
        base)
            phase_base
            ;;
        runtime)
            phase_runtime_root
            ;;
        runtime-user)
            phase_runtime_user
            ;;
    esac
}

main "$@"
