create_winux_user_runtime() {
    WINUX_PHASE="runtime-user-prefix"

    local user="$WINUX_USERNAME"
    local home_dir

    home_dir="$(getent passwd "$user" | cut -d: -f6 || true)"

    if [[ -z "$home_dir" || ! -d "$home_dir" ]]; then
        runtime_log "User home not found for '$user'. Skipping user Wine prefix setup."
        return 0
    fi

    runtime_log "Creating Winux user runtime for: $user"

    install -d -m 755 "$home_dir/.winux"
    install -d -m 755 "$home_dir/.winux/prefixes"
    install -d -m 755 "$home_dir/.winux/prefixes/apps"
    install -d -m 755 "$home_dir/.winux/prefixes/games"
    install -d -m 755 "$home_dir/.local/bin"
    install -d -m 755 "$home_dir/Desktop"

    cat > "$home_dir/.local/bin/winux-run-app" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

export WINEPREFIX="$HOME/.winux/prefixes/apps"
export WINEARCH=win64

if [[ $# -lt 1 ]]; then
    echo "Usage: winux-run-app file.exe"
    exit 1
fi

wine "$@"
EOF

    cat > "$home_dir/.local/bin/winux-run-game" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

export WINEPREFIX="$HOME/.winux/prefixes/games"
export WINEARCH=win64
export DXVK_LOG_LEVEL=none
export WINEDEBUG=-all

if command -v gamemoderun >/dev/null 2>&1; then
    exec gamemoderun wine "$@"
else
    exec wine "$@"
fi
EOF

    chmod +x "$home_dir/.local/bin/winux-run-app"
    chmod +x "$home_dir/.local/bin/winux-run-game"

    cat > "$home_dir/Desktop/Winux Wine App.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Winux Wine App Terminal
Comment=Open terminal for Winux Wine app prefix
Exec=sh -c 'cd "\$HOME" && WINEPREFIX="\$HOME/.winux/prefixes/apps" WINEARCH=win64 konsole || xterm'
Icon=wine
Terminal=false
Categories=Utility;
EOF

    chown -R "$user:$user" "$home_dir/.winux" "$home_dir/.local" "$home_dir/Desktop"

    runtime_log "Initializing Wine prefixes. This may take a while..."

    sudo -u "$user" env WINEPREFIX="$home_dir/.winux/prefixes/apps" WINEARCH=win64 wineboot -u || true
    sudo -u "$user" env WINEPREFIX="$home_dir/.winux/prefixes/games" WINEARCH=win64 wineboot -u || true

    runtime_log "User Wine prefixes created."
}

runtime_cleanup_and_mark_done() {
    WINUX_PHASE="runtime-finish"

    runtime_log "Cleaning package cache..."
    pacman -Sc --noconfirm || true

    mkdir -p /var/lib
    touch /var/lib/winux-runtime.done

    systemctl disable winux-runtime.service || true

    runtime_log "Runtime phase completed successfully."

    echo
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
    echo -e "${C_GREEN}${C_BOLD}       Winux runtime installation completed!                ${C_RESET}"
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
    echo -e "${C_CYAN}Desktop:${C_RESET} $WINUX_DE"
    echo -e "${C_CYAN}User:${C_RESET}    $WINUX_USERNAME"
    echo
    echo -e "${C_YELLOW}Wine launchers:${C_RESET}"
    echo "  winux-run-app  /path/to/app.exe"
    echo "  winux-run-game /path/to/game.exe"
    echo
    echo -e "${C_BLUE}Logs:${C_RESET}"
    echo "  /var/log/winux-runtime.log"
    echo -e "${C_GREEN}${C_BOLD}============================================================${C_RESET}"
}

run_runtime() {
    require_root

    # Runtime log should capture all output.
    exec > >(tee -a "$RUNTIME_LOG") 2>&1

    print_banner

    load_runtime_config
    runtime_prepare
    install_core_runtime
    install_de_runtime
    install_nvidia_if_requested
    install_full_wine_stack
    create_winux_user_runtime
    runtime_cleanup_and_mark_done
}

# -----------------------------
# Main
# -----------------------------

main() {
    case "${1:-}" in
        --runtime)
            run_runtime
            ;;
        --version)
            echo "Winux Installer v$VERSION"
            ;;
        *)
            run_live_install
            ;;
    esac
}

main "$@"
