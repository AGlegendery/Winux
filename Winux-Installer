    systemctl enable avahi-daemon.service || true
}

install_de_runtime() {
    WINUX_PHASE="runtime-de"

    case "$WINUX_DE" in
        kde)
            local -a kde_pkgs=(
                plasma-desktop
                plasma-workspace
                plasma-systemmonitor
                plasma-pa
                plasma-nm
                plasma-disks
                sddm
                sddm-kcm
                konsole
                dolphin
                kate
                ark
                spectacle
                kcalc
                gwenview
                okular
                powerdevil
                polkit-kde-agent
                xdg-desktop-portal
                xdg-desktop-portal-kde
            )
            adaptive_install "desktop-kde" "${kde_pkgs[@]}"
            systemctl enable sddm.service
            ;;

        xfce)
            local -a xfce_pkgs=(
                xfce4
                xfce4-goodies
                lightdm
                lightdm-gtk-greeter
                xdg-desktop-portal
                xdg-desktop-portal-gtk
            )
            adaptive_install "desktop-xfce" "${xfce_pkgs[@]}"
            systemctl enable lightdm.service
            ;;

        gnome)
            local -a gnome_pkgs=(
                gnome
                gnome-tweaks
                gdm
                xdg-desktop-portal
                xdg-desktop-portal-gnome
            )
            adaptive_install "desktop-gnome" "${gnome_pkgs[@]}"
            systemctl enable gdm.service
            ;;

        lxqt)
            local -a lxqt_pkgs=(
                lxqt
                sddm
                xdg-desktop-portal
                xdg-desktop-portal-lxqt
            )
            adaptive_install "desktop-lxqt" "${lxqt_pkgs[@]}"
            systemctl enable sddm.service
            ;;

        minimal)
            local -a minimal_pkgs=(
                openbox
                obconf
                tint2
                pcmanfm
                lxappearance
                lightdm
                lightdm-gtk-greeter
                xterm
            )
            adaptive_install "desktop-minimal" "${minimal_pkgs[@]}"
            systemctl enable lightdm.service
            ;;

        *)
            runtime_log "Unknown DE '$WINUX_DE', falling back to KDE."
            WINUX_DE="kde"
            install_de_runtime
            ;;
    esac
}

install_nvidia_if_requested() {
    WINUX_PHASE="runtime-nvidia"

    if [[ "$WINUX_INSTALL_NVIDIA" != "yes" ]]; then
