#!/usr/bin/env bash
#
# Winux v0.4 Unified Installer
# Run inside Arch Live ISO.
#
# Phase 1: Base Arch + GRUB + user
# Phase 2: KDE + Wine + Winux runtime on first boot
#

set -Eeuo pipefail

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

WINUX_PHASE="unknown"
WINUX_ERR_FIRED=0

err_handler() {
    local line="$1"
    local cmd="${2:-}"
    if [[ "$WINUX_ERR_FIRED" -eq 1 ]]; then
        return
    fi
    WINUX_ERR_FIRED=1
    echo -e "${RED}[ERROR] Failure at line ${line}, phase: ${WINUX_PHASE}.${NC}" >&2
    [[ -n "$cmd" ]] && echo -e "${RED}Command: ${cmd}${NC}" >&2
    exit 1
}
trap 'err_handler "$LINENO" "$BASH_COMMAND"' ERR

log()  { echo -e "${GREEN}[$(date +%H:%M:%S)]${NC} $*"; }
info() { echo -e "${BLUE}[$(date +%H:%M:%S)]${NC} $*"; }
warn() { echo -e "${YELLOW}[$(date +%H:%M:%S)] WARNING:${NC} $*"; }
die()  { echo -e "${RED}ERROR:${NC} $*" >&2; exit 1; }

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

confirm() {
    local prompt="$1"
    local default="${2:-n}"
    local reply=""
    if [[ "$default" =~ ^[Yy]$ ]]; then
        read -r -p "$prompt [Y/n] " reply || reply=""
        reply="${reply:-y}"
    else
        read -r -p "$prompt [y/N] " reply || reply=""
        reply="${reply:-n}"
    fi
    [[ "$reply" =~ ^[Yy]$ ]]
}

ask_value_var() {
    local __var_name="$1"
    local label="$2"
    local default="$3"
    local value=""
    read -r -p "$label [default: $default]: " value || value=""
    printf -v "$__var_name" '%s' "${value:-$default}"
}

ask_secret_var() {
    local __var_name="$1"
    local label="$2"
    local default="$3"
    local value=""
    local value2=""

    while true; do
        read -r -s -p "$label [default: hidden, Enter to use default]: " value || value=""
        echo >&2

        if [[ -z "$value" ]]; then
            value="$default"
            break
        fi

        read -r -s -p "Repeat password: " value2 || value2=""
        echo >&2

        if [[ "$value" != "$value2" ]]; then
            warn "Passwords do not match. Try again."
            continue
        fi
        break
    done

    [[ -n "$value" ]] || die "Password cannot be empty."
    [[ "$value" != *$'\n'* && "$value" != *$'\r'* ]] || die "Password cannot contain newline characters."
    printf -v "$__var_name" '%s' "$value"
}

validate_username() {
    local u="$1"
    [[ -n "$u" ]] || die "Username cannot be empty."
    [[ "$u" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]] || die "Invalid username: $u"
}

validate_hostname() {
    local h="$1"
    [[ -n "$h" ]] || die "Hostname cannot be empty."
    [[ "$h" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]{0,62}$ ]] || die "Invalid hostname: $h"
}

base64_one_line() {
    printf '%s' "$1" | base64 -w0
}

detect_phase() {
    if [[ "${1:-}" == "--runtime" ]]; then
        WINUX_PHASE="runtime"
        return
    fi
    if [[ "${1:-}" == "--base" ]]; then
        WINUX_PHASE="base"
        return
    fi

    if [[ -f /etc/winux.conf && -x /usr/bin/pacman && "$(id -u)" -eq 0 ]]; then
        WINUX_PHASE="runtime"
    else
        WINUX_PHASE="base"
    fi
}

collect_user_input() {
    [[ -t 0 ]] || die "Run this installer directly in an interactive TTY. Do not pipe it."

    echo -e "${BLUE}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║              Winux v0.4 Installer Config             ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════╝${NC}"
    echo

    info "Detected disks:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL | sed 's/^/    /'
    echo

    local default_disk="/dev/sda"
    [[ -b /dev/vda ]] && default_disk="/dev/vda"
    [[ -b /dev/nvme0n1 ]] && default_disk="/dev/nvme0n1"

    ask_value_var DISK "Target disk" "$default_disk"
    [[ -b "$DISK" ]] || die "Disk not found: $DISK"

    ask_value_var HOSTNAME "Hostname" "winux-pc"
    validate_hostname "$HOSTNAME"

    ask_value_var USERNAME "Username" "arash"
    validate_username "$USERNAME"

    ask_secret_var PASSWORD "Password" "123"

    ask_value_var TIMEZONE "Timezone" "Asia/Tehran"
    [[ -f "/usr/share/zoneinfo/$TIMEZONE" ]] || die "Invalid timezone: $TIMEZONE"

    ask_value_var LOCALE "Locale" "en_US.UTF-8"

    echo
    echo -e "${YELLOW}════════════════ INSTALL SUMMARY ════════════════${NC}"
    echo "Disk     : $DISK"
    echo "Hostname : $HOSTNAME"
    echo "Username : $USERNAME"
    echo "Password : hidden, length=${#PASSWORD}"
    echo "Timezone : $TIMEZONE"
    echo "Locale   : $LOCALE"
    echo -e "${YELLOW}═════════════════════════════════════════════════${NC}"
    echo
    echo -e "${RED}WARNING: All data on $DISK will be destroyed.${NC}"

    confirm "Proceed?" "n" || { echo "Aborted."; exit 0; }
}

preflight_checks() {
    log "Running preflight checks..."

    local cmds=(
        sgdisk mkfs.vfat mkfs.ext4 pacstrap genfstab arch-chroot
        base64 ping sed grep awk
    )
    for c in "${cmds[@]}"; do
        require_cmd "$c"
    done

    [[ -d /sys/firmware/efi/efivars ]] || die "System is not booted in UEFI mode. Enable Use EFI in VM."

    info "Checking internet..."
    ping -c1 -W3 archlinux.org >/dev/null 2>&1 || die "No internet connection."
    log "Internet OK."
}

get_partitions() {
    PART_EFI="${DISK}1"
    PART_ROOT="${DISK}2"
    if [[ "$DISK" =~ nvme || "$DISK" =~ mmcblk || "$DISK" =~ loop ]]; then
        PART_EFI="${DISK}p1"
        PART_ROOT="${DISK}p2"
    fi
}

write_winux_conf() {
    cat > /mnt/etc/winux.conf <<EOF
WINUX_VERSION="0.4"
WINUX_DISK="$DISK"
WINUX_HOSTNAME="$HOSTNAME"
WINUX_USERNAME="$USERNAME"
WINUX_TIMEZONE="$TIMEZONE"
WINUX_LOCALE="$LOCALE"
EOF
}

write_system_text_config() {
    log "Writing system text configs..."

    echo "$HOSTNAME" > /mnt/etc/hostname

    cat > /mnt/etc/hosts <<EOF
127.0.0.1   localhost
::1         localhost
127.0.0.1   ${HOSTNAME}.localdomain ${HOSTNAME}
EOF

    echo "LANG=${LOCALE}" > /mnt/etc/locale.conf

    if ! grep -q "^${LOCALE} UTF-8" /mnt/etc/locale.gen; then
        echo "${LOCALE} UTF-8" >> /mnt/etc/locale.gen
    fi
}

write_chroot_script() {
    log "Writing chroot configuration script..."

    local user_b64 pass_b64 tz_b64
    user_b64="$(base64_one_line "$USERNAME")"
    pass_b64="$(base64_one_line "$PASSWORD")"
    tz_b64="$(base64_one_line "$TIMEZONE")"

    mkdir -p /mnt/root

    cat > /mnt/root/winux-chroot.sh <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail

decode_b64() {
    printf '%s' "\$1" | base64 -d
}

NEW_USER="\$(decode_b64 '$user_b64')"
NEW_PASS="\$(decode_b64 '$pass_b64')"
TZ="\$(decode_b64 '$tz_b64')"

[[ -n "\$NEW_USER" ]] || { echo "FATAL: NEW_USER is empty" >&2; exit 1; }
[[ -n "\$NEW_PASS" ]] || { echo "FATAL: NEW_PASS is empty" >&2; exit 1; }
[[ "\$NEW_PASS" != *\$'\\n'* && "\$NEW_PASS" != *\$'\\r'* ]] || { echo "FATAL: password contains newline" >&2; exit 1; }

echo "[chroot] Configuring timezone..."
ln -sf "/usr/share/zoneinfo/\$TZ" /etc/localtime
hwclock --systohc

echo "[chroot] Generating locale..."
locale-gen

echo "[chroot] Creating user..."
if ! id "\$NEW_USER" >/dev/null 2>&1; then
    useradd -m -G wheel -s /bin/bash "\$NEW_USER"
fi

echo "[chroot] Setting passwords..."
printf '%s:%s\n' "\$NEW_USER" "\$NEW_PASS" | chpasswd
printf 'root:%s\n' "\$NEW_PASS" | chpasswd

echo "[chroot] Configuring sudo..."
install -d -m 0750 /etc/sudoers.d
cat > /etc/sudoers.d/10-wheel <<'SUDOEOF'
%wheel ALL=(ALL:ALL) ALL
SUDOEOF
chmod 440 /etc/sudoers.d/10-wheel

echo "[chroot] Installing bootloader..."
pacman -S --needed --noconfirm grub efibootmgr

grub-install \
    --target=x86_64-efi \
    --efi-directory=/boot/efi \
    --bootloader-id=Winux-GRUB

if grep -q '^GRUB_TIMEOUT=' /etc/default/grub; then
    sed -i 's/^GRUB_TIMEOUT=.*/GRUB_TIMEOUT=0/' /etc/default/grub
else
    echo 'GRUB_TIMEOUT=0' >> /etc/default/grub
fi

if grep -q '^GRUB_TIMEOUT_STYLE=' /etc/default/grub; then
    sed -i 's/^GRUB_TIMEOUT_STYLE=.*/GRUB_TIMEOUT_STYLE=hidden/' /etc/default/grub
else
    echo 'GRUB_TIMEOUT_STYLE=hidden' >> /etc/default/grub
fi

grub-mkconfig -o /boot/grub/grub.cfg

echo "[chroot] Enabling NetworkManager..."
systemctl enable NetworkManager.service

echo "[chroot] Done."
EOF

    chmod +x /mnt/root/winux-chroot.sh
}

create_runtime_service() {
    log "Creating first-boot runtime service..."

    mkdir -p /mnt/etc/systemd/system
    mkdir -p /mnt/etc/systemd/system/multi-user.target.wants

    cat > /mnt/etc/systemd/system/winux-runtime.service <<'EOF'
[Unit]
Description=Winux Runtime Installer Phase 2
Wants=network-online.target
After=network-online.target NetworkManager.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/winux-installer.sh --runtime
ExecStartPost=/usr/bin/systemctl disable winux-runtime.service
StandardOutput=journal+console
StandardError=journal+console
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
EOF

    ln -sf /etc/systemd/system/winux-runtime.service \
        /mnt/etc/systemd/system/multi-user.target.wants/winux-runtime.service
}

phase_base() {
    WINUX_PHASE="base"
    echo -e "${BLUE}=== Winux v0.4 Base Installation ===${NC}"

    collect_user_input
    preflight_checks
    get_partitions

    log "Partitioning $DISK..."
    swapoff -a 2>/dev/null || true
    umount -R /mnt 2>/dev/null || true

    sgdisk --zap-all "$DISK"
    sgdisk --new=1:0:+512M --typecode=1:ef00 --change-name=1:EFI "$DISK"
    sgdisk --new=2:0:0 --typecode=2:8300 --change-name=2:ROOT "$DISK"

    partprobe "$DISK" 2>/dev/null || true
    sleep 2

    [[ -b "$PART_EFI" ]] || die "EFI partition not found: $PART_EFI"
    [[ -b "$PART_ROOT" ]] || die "ROOT partition not found: $PART_ROOT"

    log "Formatting partitions..."
    mkfs.vfat -F32 "$PART_EFI"
    mkfs.ext4 -F "$PART_ROOT"

    log "Mounting partitions..."
    mount "$PART_ROOT" /mnt
    mkdir -p /mnt/boot/efi
    mount "$PART_EFI" /mnt/boot/efi

    log "Installing base system..."
    pacstrap -K /mnt \
        base \
        base-devel \
        linux \
        linux-firmware \
        sudo \
        nano \
        networkmanager \
        git \
        wget \
        curl \
        grub \
        efibootmgr

    log "Generating fstab..."
    genfstab -U /mnt > /mnt/etc/fstab

    write_winux_conf
    write_system_text_config

    log "Copying installer into installed system..."
    install -Dm755 "$0" /mnt/usr/local/bin/winux-installer.sh

    write_chroot_script

    log "Running chroot configuration..."
    arch-chroot /mnt /bin/bash /root/winux-chroot.sh

    rm -f /mnt/root/winux-chroot.sh
    create_runtime_service

    echo
    log "Base installation completed."
    info "Now run:"
    echo
    echo "    umount -R /mnt"
    echo "    reboot"
    echo
    info "Runtime phase will run automatically on first boot."
}

fix_multilib() {
    log "Ensuring multilib repository is enabled..."

    if grep -q '^[[:space:]]*#\s*\[multilib\]' /etc/pacman.conf; then
        sed -i '/^[[:space:]]*#\s*\[multilib\]/,/^[[:space:]]*#\s*Include[[:space:]]*=[[:space:]]*\/etc\/pacman.d\/mirrorlist/ s/^[[:space:]]*#\s*//' /etc/pacman.conf
    fi

    if ! grep -q '^[[:space:]]*\[multilib\]' /etc/pacman.conf; then
        cat >> /etc/pacman.conf <<'EOF'

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
    fi

    grep -q '^[[:space:]]*Include[[:space:]]*=[[:space:]]*/etc/pacman.d/mirrorlist' <(
        awk '
            BEGIN{in_multilib=0}
            /^[[:space:]]*\[multilib\][[:space:]]*$/ {in_multilib=1; next}
            /^[[:space:]]*\[/ && $0 !~ /^[[:space:]]*\[multilib\][[:space:]]*$/ {in_multilib=0}
            in_multilib {print}
        ' /etc/pacman.conf
    ) || cat >> /etc/pacman.conf <<'EOF'
[multilib]
Include = /etc/pacman.d/mirrorlist
EOF
}

pacman_refresh() {
    log "Refreshing pacman databases and cleaning partial downloads..."
    rm -f /var/cache/pacman/pkg/*.part 2>/dev/null || true
    pacman -Syy --noconfirm
}

retry_pacman() {
    local tries=3
    local n=1

    while true; do
        if "$@"; then
            return 0
        fi

        if (( n >= tries )); then
            warn "Command failed after ${tries} attempts."
            return 1
        fi

        warn "Command failed. Retrying (${n}/${tries})..."
        sleep 3
        pacman_refresh
        ((n++))
    done
}

check_pkg_availability() {
    local missing=()
    local pkg

    for pkg in "$@"; do
        if ! pacman -Si "$pkg" >/dev/null 2>&1; then
            missing+=("$pkg")
        fi
    done

    if (( ${#missing[@]} > 0 )); then
        printf '%s\n' "${missing[@]}" >&2
        die "Some packages are unavailable in enabled repos. See list above."
    fi
}

install_desktop_batch() {
    local pkgs=(
        xorg
        xorg-server
        plasma-desktop
        sddm
        konsole
        pcmanfm-qt
        lxqt-qtplugin
        lxqt-policykit
        gvfs
        gvfs-mtp
        gvfs-smb
        xarchiver
        firefox
        networkmanager
    )

    log "Installing desktop batch..."
    check_pkg_availability "${pkgs[@]}"
    retry_pacman pacman -S --needed --noconfirm "${pkgs[@]}"

    systemctl enable sddm.service
    systemctl enable NetworkManager.service
}

install_media_batch() {
    local pkgs=(
        pipewire
        pipewire-pulse
        pipewire-alsa
        pipewire-jack
        wireplumber
        mesa
        lib32-mesa
        vulkan-icd-loader
        lib32-vulkan-icd-loader
        gamemode
        lib32-gamemode
        noto-fonts
        noto-fonts-emoji
        ttf-dejavu
        ttf-liberation
        fontconfig
        ffmpeg
        git
        wget
        curl
    )

    log "Installing media/graphics batch..."
    check_pkg_availability "${pkgs[@]}"
    retry_pacman pacman -S --needed --noconfirm "${pkgs[@]}"
}

install_wine_batch() {
    local pkgs=(
        wine
        wine-mono
        wine-gecko
        winetricks
        giflib lib32-giflib
        libpng lib32-libpng
        libxml2 lib32-libxml2
        libxslt lib32-libxslt
        gnutls lib32-gnutls
        mpg123 lib32-mpg123
        openal lib32-openal
        v4l-utils lib32-v4l-utils
        libpulse lib32-libpulse
        libgpg-error lib32-libgpg-error
        alsa-plugins lib32-alsa-plugins
        alsa-lib lib32-alsa-lib
        libjpeg-turbo lib32-libjpeg-turbo
        sqlite lib32-sqlite
        libxcomposite lib32-libxcomposite
        libxinerama lib32-libxinerama
        libxcursor lib32-libxcursor
        libxrandr lib32-libxrandr
        libxi lib32-libxi
        libxxf86vm lib32-libxxf86vm
        libxrender lib32-libxrender
        libcups lib32-libcups
        libldap lib32-libldap
        ocl-icd lib32-ocl-icd
        vkd3d lib32-vkd3d
        sane
        samba
        ncurses lib32-ncurses
        fontconfig lib32-fontconfig
    )

    log "Installing wine batch..."
    check_pkg_availability "${pkgs[@]}"
    retry_pacman pacman -S --needed --noconfirm "${pkgs[@]}"
}

setup_user_runtime() {
    local user="$1"
    local home_dir=""
    home_dir="$(getent passwd "$user" | cut -d: -f6)"
    [[ -n "$home_dir" ]] || die "Cannot find home directory for user: $user"

    log "Creating Winux runtime for user: $user"

    cat > /tmp/winux-user-setup.sh <<'EOF'
#!/usr/bin/env bash
set -Eeuo pipefail

mkdir -p "$HOME/.winux/prefixes/apps"
mkdir -p "$HOME/.winux/prefixes/games"
mkdir -p "$HOME/.local/bin"
mkdir -p "$HOME/.local/share/file-manager/actions"

cat > "$HOME/.local/bin/winux-run-app" <<'APPEOF'
#!/usr/bin/env bash
set -Eeuo pipefail
export WINEPREFIX="$HOME/.winux/prefixes/apps"
export WINEARCH=win64
export WINEDEBUG=-all
if [[ $# -eq 0 ]]; then
    winecfg
else
    wine "$@"
fi
APPEOF

cat > "$HOME/.local/bin/winux-run-game" <<'GAMEEOF'
#!/usr/bin/env bash
set -Eeuo pipefail
export WINEPREFIX="$HOME/.winux/prefixes/games"
export WINEARCH=win64
export WINEDEBUG=-all
export DXVK_HUD=fps
if [[ $# -eq 0 ]]; then
    winecfg
else
    wine "$@"
fi
GAMEEOF

chmod +x "$HOME/.local/bin/winux-run-app"
chmod +x "$HOME/.local/bin/winux-run-game"

cat > "$HOME/.local/share/file-manager/actions/winux-app.desktop" <<APPEOF
[Desktop Entry]
Type=Action
Name=Run with Winux Runtime
Icon=wine
Profiles=run_with_winux_app

[X-Action-Profile run_with_winux_app]
MimeTypes=application/x-msdownload;application/x-dosexec;application/vnd.microsoft.portable-executable;
Exec=$HOME/.local/bin/winux-run-app %f
APPEOF

cat > "$HOME/.local/share/file-manager/actions/winux-game.desktop" <<GAMEEOF
[Desktop Entry]
Type=Action
Name=Run with Winux Game Runtime
Icon=wine
Profiles=run_with_winux_game

[X-Action-Profile run_with_winux_game]
MimeTypes=application/x-msdownload;application/x-dosexec;application/vnd.microsoft.portable-executable;
Exec=$HOME/.local/bin/winux-run-game %f
GAMEEOF

echo "Winux user runtime configured."
EOF

    install -m755 -o "$user" -g "$user" /tmp/winux-user-setup.sh "$home_dir/.winux-user-setup.sh"
    rm -f /tmp/winux-user-setup.sh

    sudo -u "$user" -H bash "$home_dir/.winux-user-setup.sh"
    rm -f "$home_dir/.winux-user-setup.sh"
}

phase_runtime() {
    WINUX_PHASE="runtime"

    echo -e "${BLUE}=== Winux v0.4 Runtime Installation ===${NC}"

    [[ "$(id -u)" -eq 0 ]] || die "Runtime phase must run as root."
    [[ -f /etc/winux.conf ]] || die "/etc/winux.conf not found."

    # shellcheck disable=SC1091
    source /etc/winux.conf

    [[ -n "${WINUX_USERNAME:-}" ]] || die "WINUX_USERNAME missing in /etc/winux.conf"

    fix_multilib
    pacman_refresh

    install_desktop_batch
    install_media_batch
    install_wine_batch
    setup_user_runtime "$WINUX_USERNAME"

    systemctl disable winux-runtime.service 2>/dev/null || true

    echo
    log "Winux v0.4 runtime installation completed."
    info "Reboot once more if SDDM does not start automatically."
}

usage() {
    cat <<EOF
Usage:
  $0 --base       Run base installer inside Arch Live ISO
  $0 --runtime    Run runtime phase inside installed system
  $0              Auto-detect phase
EOF
}

main() {
    case "${1:-}" in
        --help|-h)
            usage
            exit 0
            ;;
        --base|--runtime|"")
            detect_phase "${1:-}"
            ;;
        *)
            usage
            exit 1
            ;;
    esac

    case "$WINUX_PHASE" in
        base) phase_base ;;
        runtime) phase_runtime ;;
        *) die "Unknown phase: $WINUX_PHASE" ;;
    esac
}

main "$@"
